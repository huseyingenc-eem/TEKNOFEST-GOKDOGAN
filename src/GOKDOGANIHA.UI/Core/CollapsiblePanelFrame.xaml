<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                    xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core">

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style TargetType="{x:Type core:CollapsiblePanelFrame}">
        <Setter Property="Background" Value="{StaticResource TacticalGlass}" />
        <Setter Property="BorderBrush" Value="{StaticResource TacticalOverlayBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type core:CollapsiblePanelFrame}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <DockPanel>
                            <!-- Tıklanabilir header — chevron + icon + title + isteğe bağlı badge -->
                            <Border x:Name="PART_Header"
                                    DockPanel.Dock="Top"
                                    Background="Transparent"
                                    Padding="10,8"
                                    Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Chevron — IsExpanded'a göre yön -->
                                    <materialIcons:MaterialIcon Grid.Column="0"
                                                                Width="12" Height="12"
                                                                VerticalAlignment="Center"
                                                                Foreground="{StaticResource TacticalTextSecondary}">
                                        <materialIcons:MaterialIcon.Style>
                                            <Style TargetType="materialIcons:MaterialIcon">
                                                <Setter Property="Kind" Value="ChevronDown" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=core:CollapsiblePanelFrame}}"
                                                                 Value="False">
                                                        <Setter Property="Kind" Value="ChevronRight" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialIcons:MaterialIcon.Style>
                                    </materialIcons:MaterialIcon>

                                    <materialIcons:MaterialIcon Grid.Column="1"
                                                                Kind="{TemplateBinding IconKind}"
                                                                Width="14" Height="14"
                                                                Margin="6,0,6,0"
                                                                Foreground="{StaticResource TacticalAccent}"
                                                                VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2"
                                               Text="{TemplateBinding Header}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TacticalTextPrimary}"
                                               VerticalAlignment="Center" />

                                    <Border Grid.Column="3"
                                            Background="{StaticResource TacticalSurfaceHi}"
                                            BorderBrush="{StaticResource TacticalOverlayBorder}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="6,1"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BadgeText, RelativeSource={RelativeSource AncestorType=core:CollapsiblePanelFrame}}"
                                                                 Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{TemplateBinding BadgeText}"
                                                   FontFamily="Consolas" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TacticalAccent}" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Açılabilir içerik bölgesi -->
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource TacticalOverlayBorder}"
                                    BorderThickness="0,1,0,0"
                                    Padding="10,8"
                                    Visibility="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}">
                                <ContentPresenter />
                            </Border>
                        </DockPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_Header" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Header" Property="Background"
                                    Value="{StaticResource TacticalSurfaceHi}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
