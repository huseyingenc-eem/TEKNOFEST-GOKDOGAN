<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                    xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core">

    <Style TargetType="{x:Type core:PanelFrame}">
        <Setter Property="Background" Value="{StaticResource TacticalGlass}" />
        <Setter Property="BorderBrush" Value="{StaticResource TacticalOverlayBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type core:PanelFrame}">
                    <!-- Outer = soft drop shadow, inner = 1px white highlight for "glass rim".
                         Two-layer border gives the smoother tactical look without heavy blur. -->
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                                  Direction="270"
                                                  ShadowDepth="4"
                                                  BlurRadius="24"
                                                  Opacity="0.5" />
                            </Border.Effect>
                        </Border>
                        <Border BorderBrush="{StaticResource TacticalOverlayHighlight}"
                                BorderThickness="1"
                                CornerRadius="13"
                                Margin="1"
                                IsHitTestVisible="False" />
                        <DockPanel Margin="{TemplateBinding Padding}">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                <materialIcons:MaterialIcon Kind="{TemplateBinding IconKind}"
                                                            Width="14" Height="14"
                                                            Foreground="{StaticResource TacticalAccent}"
                                                            VerticalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TacticalTextSecondary}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ContentPresenter />
                        </DockPanel>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
