<UserControl x:Class="GOKDOGANIHA.UI.Core.ConnectionStatusPill"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d"
             x:Name="Root">

    <!-- Ortak bağlantı rozeti: durum noktası (faz→renk) + ad + canlı durum metni +
         (Faulted'da) Tekrar Dene. Meşgul fazlarda nokta nabız atar. -->
    <Border CornerRadius="10" Padding="10,4"
            Background="{StaticResource TacticalSurfaceHi}"
            BorderBrush="{StaticResource TacticalOverlayHighlight}"
            BorderThickness="1">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- Durum noktası — renk ve nabız, faza göre. Sadece renk değil; yanında
                 her zaman metinsel durum var (erişilebilirlik: renk-körü güvenli). -->
            <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{StaticResource TacticalTextSecondary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status.Phase, ElementName=Root}" Value="Online">
                                <Setter Property="Fill" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status.Phase, ElementName=Root}" Value="Connecting">
                                <Setter Property="Fill" Value="{StaticResource TacticalWarn}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status.Phase, ElementName=Root}" Value="Retrying">
                                <Setter Property="Fill" Value="{StaticResource TacticalWarn}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status.Phase, ElementName=Root}" Value="Faulted">
                                <Setter Property="Fill" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                            <!-- Bağlanıyor / yeniden deniyor iken canlı nabız (UX: >300ms işlemde geri bildirim). -->
                            <DataTrigger Binding="{Binding Status.IsBusy, ElementName=Root}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="PulseSb">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.25" Duration="0:0:0.7"
                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="PulseSb" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>

            <!-- Ad: SUNUCU / TELEMETRİ / VİDEO -->
            <TextBlock Text="{Binding Status.Name, ElementName=Root}"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TacticalTextPrimary}"
                       Margin="7,0,6,0" VerticalAlignment="Center" />

            <!-- Canlı durum metni (Message) — kullanıcının okuduğu asıl geri bildirim. -->
            <TextBlock Text="{Binding Status.Message, ElementName=Root}"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="{StaticResource TacticalTextSecondary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="260" />

            <!-- Tekrar Dene — yalnızca Faulted'da görünür (UX: hatadan kurtulma yolu). -->
            <Button Command="{Binding RetryCommand, ElementName=Root}"
                    Cursor="Hand" Margin="8,0,0,0"
                    ToolTip="Yeniden bağlanmayı dene"
                    Background="Transparent"
                    BorderBrush="{StaticResource TacticalCritical}"
                    BorderThickness="1">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status.Phase, ElementName=Root}" Value="Faulted">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ShowRetryWhileBusy, ElementName=Root}" Value="True" />
                                    <Condition Binding="{Binding Status.Phase, ElementName=Root}" Value="Connecting" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ShowRetryWhileBusy, ElementName=Root}" Value="True" />
                                    <Condition Binding="{Binding Status.Phase, ElementName=Root}" Value="Retrying" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="7,2">
                            <StackPanel Orientation="Horizontal">
                                <materialIcons:MaterialIcon Kind="Refresh" Width="11" Height="11"
                                                            VerticalAlignment="Center"
                                                            Foreground="{StaticResource TacticalCritical}" />
                                <TextBlock Text="TEKRAR DENE" FontSize="9" FontWeight="Bold"
                                           Margin="4,0,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TacticalCritical}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FF3B30" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
