<UserControl x:Class="GOKDOGANIHA.UI.Core.KamikazePhaseStepper"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
             x:Name="Root">
    <ItemsControl ItemsSource="{Binding Steps, ElementName=Root}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Rows="1" Columns="4" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type core:KamikazePhaseStepPresentation}">
                <StackPanel HorizontalAlignment="Center">
                    <Border HorizontalAlignment="Center"
                            Background="{Binding Background}"
                            BorderBrush="{Binding BorderBrush}"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Width" Value="12" />
                                <Setter Property="Height" Value="12" />
                                <Setter Property="CornerRadius" Value="6" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Compact, RelativeSource={RelativeSource AncestorType={x:Type core:KamikazePhaseStepper}}}" Value="True">
                                        <Setter Property="Width" Value="14" />
                                        <Setter Property="Height" Value="14" />
                                        <Setter Property="CornerRadius" Value="7" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock Text="{Binding Label}"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TacticalTextSecondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Margin" Value="0,6,0,0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Compact, RelativeSource={RelativeSource AncestorType={x:Type core:KamikazePhaseStepper}}}" Value="True">
                                        <Setter Property="FontSize" Value="11" />
                                        <Setter Property="Margin" Value="0,8,0,0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
