<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                    xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core">

    <!-- SettingsSection — sol kolonda icon+başlık+subtitle, sağda Content slot.
         Settings sayfasındaki her section bu pattern'i kullanır → DRY. -->
    <Style TargetType="{x:Type core:SettingsSection}">
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type core:SettingsSection}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Sol başlık · gerçek gap kolonu · sağ içerik.
                                 Gap ayrı bir kolon olduğu için iki sütun arası mesafe net kontrol edilir. -->
                            <ColumnDefinition Width="240" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Sol kolon: Icon + Title + Subtitle.
                             Title satırı 32px height — Material Design TextBox/input minimum
                             height'i ile aynı, sağ ilk row ile yatay olarak hizalanır. -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal" Height="32">
                                <materialIcons:MaterialIcon Kind="{TemplateBinding IconKind}"
                                                            Width="18" Height="18"
                                                            Foreground="{StaticResource TacticalAccent}"
                                                            VerticalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TacticalTextPrimary}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{TemplateBinding Subtitle}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- Sağ kolon: Content (alanlar) — gap kolonundan sonra -->
                        <ContentPresenter Grid.Column="2"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
