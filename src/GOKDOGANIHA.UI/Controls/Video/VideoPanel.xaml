<UserControl x:Class="GOKDOGANIHA.UI.Controls.Video.VideoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
             xmlns:video="clr-namespace:GOKDOGANIHA.UI.Controls.Video"
             mc:Ignorable="d"
             d:DesignWidth="440" d:DesignHeight="520">

    <core:PanelFrame Header="GÖREV VİDEOSU" IconKind="Video">
        <video:RtspVideoView x:Name="LiveVideo"
                             StreamUrl="{Binding Settings.Video.RtspUrl}"
                             NetworkCachingMs="150"
                             UseTcp="True">
            <!-- LibVLC WPF airspace kuralı gereği HUD içeriği VideoView içinde
                 tutulur; böylece canlı görüntünün üzerinde görünmeye devam eder. -->
            <Grid Background="#02000000">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStreamConnected, ElementName=LiveVideo}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="— CANLI VİDEO AKIŞI —"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TacticalTextSecondary}"
                               FontFamily="Consolas" FontSize="12" />
                    <TextBlock Text="{Binding StatusText, ElementName=LiveVideo}"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TacticalTextSecondary}"
                           FontFamily="Consolas" FontSize="10"
                           Margin="0,6,0,0" />
                    <TextBlock Text="{Binding Settings.Video.RtspUrl}"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TacticalTextSecondary}"
                           FontFamily="Consolas" FontSize="10"
                           Margin="0,6,0,0"
                           Opacity="0.45" />
                </StackPanel>

                <!-- Crosshair reticle -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="60" Height="60" Opacity="0.35">
                    <Ellipse Stroke="{StaticResource TacticalAccent}" StrokeThickness="1" />
                    <Line X1="30" Y1="10" X2="30" Y2="50"
                          Stroke="{StaticResource TacticalAccent}" StrokeThickness="1" />
                    <Line X1="10" Y1="30" X2="50" Y2="30"
                          Stroke="{StaticResource TacticalAccent}" StrokeThickness="1" />
                </Grid>

            <!-- Hedef kilit dörtgeni — kamera native 640x480 space'te çizilir,
                 Viewbox panel'e uniform stretch eder. Şartname kırmızı (#FF0000) ister. -->
            <Viewbox Stretch="Uniform" IsHitTestVisible="False"
                     Visibility="{Binding HasTargetBox, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                <Canvas Width="640" Height="480">
                    <Rectangle Stroke="#FF0000" StrokeThickness="2"
                               Width="{Binding TargetWidth}"
                               Height="{Binding TargetHeight}"
                               Canvas.Left="{Binding TargetBoxLeft}"
                               Canvas.Top="{Binding TargetBoxTop}" />
                    <!-- Hedef ID etiketi (kutunun 18px üstünde) -->
                    <TextBlock Canvas.Left="{Binding TargetBoxLeft}"
                               Canvas.Top="{Binding TargetLabelTop}"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                               Foreground="#FF0000"
                               Text="{Binding TargetTeamNumber, StringFormat=T-{0:00}}" />
                </Canvas>
            </Viewbox>

            <!-- Lock progress chip — KİLİTLENME devam ederken 4 sn sayaç -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,8,0,0"
                    CornerRadius="3" Padding="10,4"
                    Background="#D9B41E1E" BorderBrush="#FF4444" BorderThickness="1"
                    Visibility="{Binding IsLockingActive, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#FF4444"
                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="KİLİTLENME"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LockProgressText}"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                               Foreground="#FFD700"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </StackPanel>
            </Border>

            <!-- Top-right stack: lock badge + expand button -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                        Orientation="Horizontal" Margin="0,8,8,0">

                <!-- Lock badge — only while a target is locked -->
                <Border Margin="0,0,6,0"
                        CornerRadius="2" Padding="6,2"
                        Background="{StaticResource TacticalCritical}"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsLocked, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                    <TextBlock Text="KİLİTLİ"
                               FontSize="10" FontWeight="Bold"
                               Foreground="White" />
                </Border>

                <!-- Expand button — the ONLY clickable element on the panel surface -->
                <Button Command="{Binding ExpandCameraCommand}"
                        Click="OnExpandClick"
                        Cursor="Hand"
                        Width="26" Height="26"
                        Padding="0"
                        Focusable="False"
                        ToolTip="Tam ekrana genişlet">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="#99000000"
                                    BorderBrush="{StaticResource TacticalOverlayBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <materialIcons:MaterialIcon Kind="Fullscreen"
                                                            Width="16" Height="16"
                                                            Foreground="{StaticResource TacticalAccent}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#CC00D1C7" />
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{StaticResource TacticalAccent}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                </StackPanel>
            </Grid>
        </video:RtspVideoView>
    </core:PanelFrame>
</UserControl>
