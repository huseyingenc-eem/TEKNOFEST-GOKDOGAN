<UserControl x:Class="GOKDOGANIHA.UI.Controls.Video.CameraFullscreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:flight="clr-namespace:GOKDOGANIHA.UI.Controls.Flight"
             xmlns:video="clr-namespace:GOKDOGANIHA.UI.Controls.Video"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720"
             Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- =========== TOP STRIP (REC / CAM / FOV / ZOOM) =========== -->
        <Grid Grid.Row="0" Margin="18,14,18,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="{StaticResource TacticalCritical}"
                         VerticalAlignment="Center">
                    <!-- Blink only while the overlay is actually visible; stops when closed. -->
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVisible, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="RecBlink">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.25" Duration="0:0:0.6"
                                                                 AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="RecBlink" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="REC" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource TacticalCritical}"
                           Margin="8,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding RecordingTime}" FontFamily="Consolas" FontSize="12"
                           Foreground="{StaticResource TacticalTextPrimary}"
                           VerticalAlignment="Center" />
                <Border Background="{StaticResource TacticalSurfaceHi}" CornerRadius="3"
                        Padding="8,3" Margin="16,0,0,0">
                    <TextBlock Text="CAM-01 · EO" FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TacticalAccent}" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="FOV" FontSize="10"
                           Foreground="{StaticResource TacticalTextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="24°" FontFamily="Consolas" FontSize="12"
                           Foreground="{StaticResource TacticalTextPrimary}"
                           VerticalAlignment="Center" Margin="0,0,18,0" />
                <TextBlock Text="ZOOM" FontSize="10"
                           Foreground="{StaticResource TacticalTextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TacticalAccent}"
                           VerticalAlignment="Center">
                    <TextBlock.Text>
                        <Binding Path="CameraZoom" StringFormat="{}{0:0.0}x" FallbackValue="1.0x" />
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- =========== VIDEO STAGE =========== -->
        <Grid Grid.Row="1" Margin="18,0,18,0" ClipToBounds="True">
            <Border BorderBrush="{StaticResource TacticalOverlayBorder}"
                    BorderThickness="1" CornerRadius="6">
                <video:RtspVideoView x:Name="FullscreenVideo"
                                     SessionKey="MissionCamera"
                                     SurfacePriority="100"
                                     StreamUrl="{Binding Settings.Video.RtspUrl}"
                                     NetworkCachingMs="{Binding Settings.Video.NetworkCachingMs}"
                                     UseTcp="{Binding Settings.Video.UseTcp}"
                                     VideoStatus="{Binding VideoConnection}">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStreamConnected, ElementName=FullscreenVideo}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="— CANLI VİDEO AKIŞI —"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   FontFamily="Consolas" FontSize="14" />
                        <TextBlock Text="{Binding StatusText, ElementName=FullscreenVideo}"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   FontFamily="Consolas" FontSize="11"
                                   Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- =========== HUD OVERLAYS =========== -->

                    <!-- Sol-alt köşe: Primary Flight Display (yapay ufuk + tape + heading).
                         Eski 3 dikey card (IAS/ALT/HDG) yerine kompakt PFD — pilot bakışı
                         için daha okunabilir, jüri tasarım puanı için profesyonel görünüm. -->
                    <flight:PrimaryFlightDisplay
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="24,0,0,24"
                        Pitch="{Binding Pitch}"
                        Roll="{Binding Roll}"
                        Heading="{Binding Heading}"
                        Altitude="{Binding Altitude}"
                        Airspeed="{Binding Airspeed}"
                        VerticalSpeed="{Binding VerticalSpeed}"
                        IsDataValid="{Binding IsVehicleDataValid}" />

                    <!-- Right stack: target lock info (visible only when locked) -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,24,0"
                            Background="#40FF5252"
                            BorderBrush="{StaticResource TacticalCritical}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="14,10" MinWidth="220"
                            Visibility="{Binding IsLockedDisplay, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <materialIcons:MaterialIcon Kind="Crosshairs" Width="14" Height="14"
                                                            Foreground="{StaticResource TacticalCritical}"
                                                            VerticalAlignment="Center" />
                                <TextBlock Text="HEDEF KİLİTLENDİ"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TacticalCritical}"
                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="ID"
                                           FontSize="10"
                                           Foreground="{StaticResource TacticalTextSecondary}"
                                           Margin="0,0,10,2" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding TargetId, FallbackValue=—}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TacticalTextPrimary}" Margin="0,0,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="MESAFE"
                                           FontSize="10"
                                           Foreground="{StaticResource TacticalTextSecondary}"
                                           Margin="0,0,10,2" />
                                <TextBlock Grid.Row="1" Grid.Column="1" FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TacticalCritical}"
                                           Margin="0,0,0,2">
                                    <TextBlock.Text>
                                        <Binding Path="TargetRange" StringFormat="{}{0:0} m" FallbackValue="— m" />
                                    </TextBlock.Text>
                                </TextBlock>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="KONFİDANS"
                                           FontSize="10"
                                           Foreground="{StaticResource TacticalTextSecondary}"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Row="2" Grid.Column="1" FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TacticalOk}">
                                    <TextBlock.Text>
                                        <Binding Path="TargetConfidence" StringFormat="{}{0}%" FallbackValue="—" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Crosshair (center, sabit) -->
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                          Width="140" Height="140" IsHitTestVisible="False">
                        <Ellipse Stroke="{StaticResource TacticalAccent}" StrokeThickness="1"
                                 Opacity="0.45" Width="36" Height="36" />
                        <Line X1="70" Y1="28" X2="70" Y2="60"
                              Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                        <Line X1="70" Y1="80" X2="70" Y2="112"
                              Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                        <Line X1="28" Y1="70" X2="60" Y2="70"
                              Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                        <Line X1="80" Y1="70" X2="112" Y2="70"
                              Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                    </Grid>

                    <!-- Hedef kilit dörtgeni — kamera native 640x480 koordinatlarında.
                         Şartname kırmızı (#FF0000) + video kayıtta görünür olmalı. -->
                    <Viewbox Stretch="Uniform" IsHitTestVisible="False"
                             Visibility="{Binding HasTargetBox, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                        <Canvas Width="640" Height="480">
                            <Rectangle Stroke="#FF0000" StrokeThickness="2"
                                       Width="{Binding TargetWidth}"
                                       Height="{Binding TargetHeight}"
                                       Canvas.Left="{Binding TargetBoxLeft}"
                                       Canvas.Top="{Binding TargetBoxTop}" />
                            <TextBlock Canvas.Left="{Binding TargetBoxLeft}"
                                       Canvas.Top="{Binding TargetLabelTop}"
                                       FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                       Foreground="#FF0000"
                                       Text="{Binding TargetTeamNumber, StringFormat=T-{0:00}}" />
                        </Canvas>
                    </Viewbox>

                    <!-- Lock progress chip — şartname 4s sayaç (KİLİTLENME 2.7s / 4.0s) -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,12,0,0"
                            CornerRadius="3" Padding="14,5"
                            Background="#D9B41E1E" BorderBrush="#FF4444" BorderThickness="1"
                            Visibility="{Binding IsLockingActive, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" Fill="#FF4444"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="KİLİTLENME"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding LockProgressText}"
                                       FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                       Foreground="#FFD700"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ŞARTNAME ZORUNLU: Sunucu saati ms hassasiyetinde, sağ üstte,
                         video kayıtta görünür konumda (yarışma teknik kontrolü). -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,12,0"
                            CornerRadius="3" Padding="10,4"
                            Background="#B3000000" BorderBrush="#666" BorderThickness="1">
                        <TextBlock Text="{Binding ServerTime}"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="#F1C40F" />
                    </Border>
                </Grid>
                </video:RtspVideoView>
            </Border>
        </Grid>

        <!-- =========== BOTTOM ACTION BAR =========== -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="18,14,18,18">
            <Button Command="{Binding CameraZoomOutCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" Padding="18,8">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="MagnifyMinus" Width="16" Height="16"
                                                VerticalAlignment="Center" />
                    <TextBlock Text="ZOOM −" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Command="{Binding ToggleCameraBandCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" Padding="18,8">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="Contrast" Width="16" Height="16"
                                                VerticalAlignment="Center" />
                    <TextBlock Text="EO / IR" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Lock / unlock primary action -->
            <Button Command="{Binding ToggleLockCommand}"
                    Margin="0,0,8,0" Padding="24,10" FontWeight="SemiBold">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                        <Setter Property="Background" Value="{StaticResource TacticalAccent}" />
                        <Setter Property="BorderBrush" Value="{StaticResource TacticalAccent}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLockedDisplay}" Value="True">
                                <Setter Property="Background" Value="{StaticResource TacticalCritical}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="Crosshairs" Width="18" Height="18"
                                                VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="KİLİTLE" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLockedDisplay}" Value="True">
                                        <Setter Property="Text" Value="KİLİDİ BIRAK" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>

            <Button Command="{Binding CameraSnapshotCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" Padding="18,8">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="Camera" Width="16" Height="16"
                                                VerticalAlignment="Center" />
                    <TextBlock Text="SNAPSHOT" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Command="{Binding CameraZoomInCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Padding="18,8">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="MagnifyPlus" Width="16" Height="16"
                                                VerticalAlignment="Center" />
                    <TextBlock Text="ZOOM +" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
