<UserControl x:Class="GOKDOGANIHA.UI.Controls.Shell.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
             mc:Ignorable="d"
             d:DesignWidth="1600" d:DesignHeight="44">

    <UserControl.Resources>
        <!-- Pill-shaped icon button (matches StatusPill metrics so header reads as one unit). -->
        <Style x:Key="HeaderIconPillButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="{StaticResource TacticalSurfaceHi}" />
            <Setter Property="BorderBrush" Value="{StaticResource TacticalOverlayBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Pill"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="10,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background"
                                        Value="{StaticResource TacticalSurface}" />
                                <Setter TargetName="Pill" Property="BorderBrush"
                                        Value="{StaticResource TacticalAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Pill" Property="Background"
                                        Value="{StaticResource TacticalBgDeep}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active overlay "breadcrumb" chip — shown while Camera / Settings overlay is open. -->
        <Style x:Key="OverlayChipCloseButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBg" Background="Transparent" CornerRadius="2" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource TacticalGlass}"
            BorderBrush="{StaticResource TacticalOverlayBorder}"
            BorderThickness="0,0,0,1"
            Padding="16,10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="3" BlurRadius="18" Opacity="0.45" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- ========== LEFT: Identity (logo + callsign) ========== -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <materialIcons:MaterialIcon Kind="Airplane"
                                            Width="22" Height="22"
                                            Foreground="{StaticResource TacticalAccent}"
                                            VerticalAlignment="Center" />
                <TextBlock Text="{Binding Settings.Team.CallSign}"
                           FontSize="16" FontWeight="SemiBold"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- ========== CENTER: Server clock ========== -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <materialIcons:MaterialIcon Kind="ClockOutline"
                                            Width="16" Height="16"
                                            Foreground="{StaticResource TacticalTextSecondary}"
                                            VerticalAlignment="Center" />
                <TextBlock Text="SUNUCU SAATİ"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TacticalTextSecondary}"
                           Margin="6,0,10,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding ServerTime}"
                           FontFamily="Consolas" FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TacticalTextPrimary}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- ========== RIGHT: Active overlay · Mode · Link · API · Battery · Settings ========== -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Active overlay chip — Camera -->
                <Border Background="#3300D1C7"
                        BorderBrush="{StaticResource TacticalAccent}"
                        BorderThickness="1" CornerRadius="3"
                        Padding="8,4" Margin="0,0,8,0"
                        Visibility="{Binding IsCameraFullscreen, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                    <StackPanel Orientation="Horizontal">
                        <materialIcons:MaterialIcon Kind="Video" Width="13" Height="13"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="KAMERA"
                                   FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TacticalAccent}"
                                   Margin="6,0,8,0" VerticalAlignment="Center" />
                        <Button Command="{Binding CloseActiveOverlayCommand}"
                                Style="{StaticResource OverlayChipCloseButton}"
                                ToolTip="Kapat">
                            <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"
                                                        Foreground="{StaticResource TacticalAccent}" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Active overlay chip — Settings -->
                <Border Background="#3300D1C7"
                        BorderBrush="{StaticResource TacticalAccent}"
                        BorderThickness="1" CornerRadius="3"
                        Padding="8,4" Margin="0,0,8,0"
                        Visibility="{Binding IsSettingsOpen, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}">
                    <StackPanel Orientation="Horizontal">
                        <materialIcons:MaterialIcon Kind="Cog" Width="13" Height="13"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="AYARLAR"
                                   FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TacticalAccent}"
                                   Margin="6,0,8,0" VerticalAlignment="Center" />
                        <Button Command="{Binding CloseActiveOverlayCommand}"
                                Style="{StaticResource OverlayChipCloseButton}"
                                ToolTip="Kapat">
                            <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12"
                                                        Foreground="{StaticResource TacticalAccent}" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Telemetry / status pills -->
                <core:StatusPill IconKind="Cog"
                                 IconBrush="{StaticResource TacticalAccent}"
                                 Label="MOD"
                                 Value="{Binding FlightMode}" />
                <core:StatusPill IconKind="AccessPoint"
                                 IconBrush="{StaticResource TacticalOk}"
                                 Label="LINK"
                                 Value="{Binding LinkRssi, StringFormat={}{0} dBm}"
                                 Margin="8,0,0,0" />
                <core:StatusPill IconKind="Server"
                                 IconBrush="{StaticResource TacticalAccent}"
                                 Label="API"
                                 Value="{Binding ServerLatencyMs, StringFormat={}{0} ms}"
                                 Margin="8,0,0,0" />
                <core:StatusPill IconKind="BatteryHigh"
                                 IconBrush="{StaticResource TacticalOk}"
                                 Label="BAT"
                                 Value="{Binding Battery, StringFormat={}{0}%}"
                                 Margin="8,0,0,0" />

                <!-- Settings pill-button (matches StatusPill geometry) -->
                <Button Command="{Binding OpenSettingsCommand}"
                        Click="OnSettingsClick"
                        Style="{StaticResource HeaderIconPillButton}"
                        ToolTip="Ayarlar"
                        Margin="8,0,0,0">
                    <materialIcons:MaterialIcon Kind="Cog" Width="16" Height="16"
                                                Foreground="{StaticResource TacticalTextSecondary}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
