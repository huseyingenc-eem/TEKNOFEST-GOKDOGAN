<UserControl x:Class="GOKDOGANIHA.UI.Controls.Sidebar.RightSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
             xmlns:alerts="clr-namespace:GOKDOGANIHA.UI.Controls.Alerts"
             xmlns:panels="clr-namespace:GOKDOGANIHA.UI.Controls.Sidebar.Panels"
             mc:Ignorable="d"
             d:DesignWidth="360" d:DesignHeight="900">

    <!-- Sağ kolon — tab tabanlı 3 grup. Tab içinde collapsible paneller dikey yığılır;
         kullanıcı tab değiştirerek bağlamı değiştirir. Settings'te de aynı IconTabItem
         pattern'i kullanılıyor (DRY).
         GÖREV  → Rakipler/Kilitlenme/Kamikaze (muharebe odaklı)
         SİSTEM → Sunucu/Güvenlik/Komutlar (operasyonel)
         GÜNLÜK → Olay log (geniş alan) -->
    <Border Background="{StaticResource TacticalGlass}"
            BorderBrush="{StaticResource TacticalOverlayBorder}"
            BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ========== HEADER: Batarya · Sunucu Saati ==========
                 Tek kart içinde 2 sütun (BAT 1 tab genişliği, SAAT kalan). Aralarında
                 ince dikey ayraç. Renkler birebir aynı (tek Border = tek bg), çizgi
                 hizalaması net. -->
            <Border Grid.Row="0"
                    Background="{StaticResource TacticalGlass}"
                    BorderBrush="{StaticResource TacticalOverlayBorder}"
                    BorderThickness="1" CornerRadius="4"
                    Margin="10,10,10,10">
                <!-- TopBar ile aynı: kart altında yumuşak gölge → bitiş çizgisi etkisi -->
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270"
                                      ShadowDepth="3" BlurRadius="18" Opacity="0.45" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- 1 tab genişliği (sidebar iç ≈ 400, /3 ≈ 130) -->
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- BAT — sol, tek satır (SAAT ile aynı yükseklik):
                         [icon] BAT [progress bar] % -->
                    <Grid Grid.Column="0" Margin="12,7,12,7" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <materialIcons:MaterialIcon Grid.Column="0"
                                                    Kind="BatteryHigh"
                                                    Width="14" Height="14"
                                                    Foreground="{StaticResource TacticalOk}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="BAT"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   Margin="4,0,8,0"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="2"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding BatteryProgressValue, Mode=OneWay}"
                                     Height="6" VerticalAlignment="Center"
                                     Background="{StaticResource TacticalBgDeep}"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TacticalOk}" />
                        <TextBlock Grid.Column="3" Text="{Binding BatteryDisplay}"
                                   FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Dikey ayraç -->
                    <Border Grid.Column="1"
                            Background="{StaticResource TacticalOverlayBorder}"
                            Margin="0,8" />

                    <!-- SAAT — sağ -->
                    <Grid Grid.Column="2" Margin="12,7,12,7">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="ClockOutline"
                                                        Width="14" Height="14"
                                                        Foreground="{StaticResource TacticalAccent}"
                                                        VerticalAlignment="Center" />
                            <TextBlock Text="SUNUCU SAATİ"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding ServerTime}"
                                   FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Grid>
            </Border>

            <!-- ========== TAB CONTROL ========== -->
            <TabControl Grid.Row="1"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        SelectedIndex="0">
            <core:IconTabItem IconKind="Sword" Label="GÖREV">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,4,10,12">
                    <StackPanel>
                        <core:CollapsiblePanelFrame Header="RAKİP İHA'LAR"
                                                    IconKind="Airplane"
                                                    IsExpanded="True">
                            <panels:OpponentsPanel DataContext="{Binding MapVm}" />
                        </core:CollapsiblePanelFrame>

                        <core:CollapsiblePanelFrame Header="KİLİTLENME"
                                                    IconKind="Crosshairs"
                                                    IsExpanded="True">
                            <panels:LockOnPanel />
                        </core:CollapsiblePanelFrame>

                        <core:CollapsiblePanelFrame Header="KAMİKAZE"
                                                    IconKind="Bomb"
                                                    IsExpanded="True">
                            <panels:KamikazePanel />
                        </core:CollapsiblePanelFrame>
                    </StackPanel>
                </ScrollViewer>
            </core:IconTabItem>

            <core:IconTabItem IconKind="Cog" Label="SİSTEM">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,4,10,12">
                    <StackPanel>
                        <core:CollapsiblePanelFrame Header="SUNUCU HABERLEŞME"
                                                    IconKind="Web"
                                                    IsExpanded="True">
                            <panels:ServerCommPanel />
                        </core:CollapsiblePanelFrame>

                        <core:CollapsiblePanelFrame Header="GÜVENLİK / UYARILAR"
                                                    IconKind="ShieldAlert"
                                                    IsExpanded="True">
                            <panels:SafetyPanel />
                        </core:CollapsiblePanelFrame>

                        <core:CollapsiblePanelFrame Header="KOMUTLAR"
                                                    IconKind="Controller"
                                                    IsExpanded="True">
                            <panels:CommandsPanel />
                        </core:CollapsiblePanelFrame>
                    </StackPanel>
                </ScrollViewer>
            </core:IconTabItem>

            <core:IconTabItem IconKind="FormatListBulleted" Label="GÜNLÜK">
                <!-- Olay günlüğü tüm tab alanını kaplasın — diğer panellerden büyük. -->
                <Border Margin="8" Padding="8"
                        Background="{StaticResource TacticalGlass}"
                        BorderBrush="{StaticResource TacticalOverlayBorder}"
                        BorderThickness="1" CornerRadius="6">
                    <alerts:AlertConsole />
                </Border>
            </core:IconTabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
