<UserControl x:Class="GOKDOGANIHA.UI.Controls.Sidebar.Panels.KamikazePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="280">

    <UserControl.Resources>
        <!-- Faz dot taban stili — 4 dot ortak; her birinin kendi DataTrigger zinciri var.
             Hata fazında HEPSİ kırmızı yansır (visual feedback: görev başarısız). -->
        <Style x:Key="PhaseDot" TargetType="Border">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background" Value="{StaticResource TacticalSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource TacticalOverlayBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <!-- DataContext = MainWindowViewModel — KamikazePhase, KamikazeStatus, KamikazeQrText etc. -->
    <StackPanel>
        <!-- Faz göstergesi: 4 dot + label (INTIKAL → DALIŞ → QR → PAS GEÇ).
             Aktif faza göre dolar, geçilmiş fazlar yeşil, başarısız hata kırmızı. -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Dot row -->
            <Border Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PhaseDot}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata">
                                <Setter Property="Background" Value="{StaticResource TacticalCritical}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Intikal">
                                <Setter Property="Background" Value="{StaticResource TacticalAccent}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalAccent}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Dalis">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrOkundu">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PhaseDot}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata">
                                <Setter Property="Background" Value="{StaticResource TacticalCritical}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Dalis">
                                <Setter Property="Background" Value="{StaticResource TacticalWarn}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalWarn}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrOkundu">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PhaseDot}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata">
                                <Setter Property="Background" Value="{StaticResource TacticalCritical}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor">
                                <Setter Property="Background" Value="{StaticResource TacticalAccent}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalAccent}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrOkundu">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Border Grid.Row="0" Grid.Column="3" HorizontalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PhaseDot}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata">
                                <Setter Property="Background" Value="{StaticResource TacticalCritical}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec">
                                <Setter Property="Background" Value="{StaticResource TacticalAccent}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalAccent}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam">
                                <Setter Property="Background" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Label row -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="İNTİKAL" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center" Margin="0,4,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="DALIŞ" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center" Margin="0,4,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="QR" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center" Margin="0,4,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="PAS GEÇ" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center" Margin="0,4,0,0" />
        </Grid>

        <!-- Durum metni — FSM'den canlı (renk severity'ye göre) -->
        <Border Background="{StaticResource TacticalSurface}"
                BorderBrush="{StaticResource TacticalOverlayBorder}"
                BorderThickness="1" CornerRadius="3"
                Padding="8,6" Margin="0,0,0,8">
            <TextBlock Text="{Binding KamikazeStatus}"
                       FontSize="10" FontWeight="SemiBold"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource TacticalTextPrimary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata">
                                <Setter Property="Foreground" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam">
                                <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- Detaylar -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="QR KONUM" Style="{StaticResource MetricLabel}" Margin="0,0,12,3" />
            <TextBlock Grid.Row="0" Grid.Column="1" FontFamily="Consolas" FontSize="10"
                       Foreground="{StaticResource TacticalAccent}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:F4}, {1:F4}" FallbackValue="—">
                        <Binding Path="MapVm.QrTarget.Enlem" />
                        <Binding Path="MapVm.QrTarget.Boylam" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="QR METNİ" Style="{StaticResource MetricLabel}" Margin="0,0,12,3" />
            <TextBlock Grid.Row="1" Grid.Column="1" FontFamily="Consolas" FontSize="10"
                       Text="{Binding KamikazeQrText, FallbackValue=—, TargetNullValue=—}"
                       Foreground="{StaticResource TacticalOk}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="DENEME" Style="{StaticResource MetricLabel}" Margin="0,0,12,0" />
            <TextBlock Grid.Row="2" Grid.Column="1" FontFamily="Consolas" FontSize="10"
                       Foreground="{StaticResource TacticalTextPrimary}">
                <TextBlock.Text>
                    <Binding Path="KamikazeAttempt" StringFormat="{}{0} / 2" />
                </TextBlock.Text>
            </TextBlock>
        </Grid>

        <!-- Aksiyon butonları — Başlat / Mock QR (debug) / İptal -->
        <UniformGrid Columns="3">
            <Button Margin="0,0,2,0"
                    Padding="6,6"
                    Background="#3A2A10"
                    BorderBrush="#6A4A20"
                    BorderThickness="1"
                    Foreground="{StaticResource TacticalWarn}"
                    FontWeight="Bold" FontSize="9"
                    Cursor="Hand"
                    Command="{Binding StartKamikazeCommand}"
                    ToolTip="QR koordinatına kamikaze görevi başlat">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="Bomb" Width="11" Height="11" VerticalAlignment="Center" />
                    <TextBlock Text="BAŞLAT" Margin="4,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <!-- QR SİM debug butonu — yalnızca Settings'te simülatör açıkken görünür.
                 Üretim modunda gizli, jüri ekranında karışıklık yaratmaz. -->
            <Button Margin="2,0,2,0"
                    Padding="6,6"
                    Background="{StaticResource TacticalSurface}"
                    BorderBrush="{StaticResource TacticalOverlayBorder}"
                    BorderThickness="1"
                    Foreground="{StaticResource TacticalAccent}"
                    FontWeight="SemiBold" FontSize="9"
                    Cursor="Hand"
                    Command="{Binding SimulateQrReadCommand}"
                    Visibility="{Binding Settings.Telemetry.IsSimulationActive,
                                 Converter={x:Static md:BooleanToVisibilityConverter.CollapsedInstance}}"
                    ToolTip="DEBUG: gerçek kamera/YOLO yokken FSM'i ileri it">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="QrcodeScan" Width="11" Height="11" VerticalAlignment="Center" />
                    <TextBlock Text="QR SİM" Margin="4,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Margin="2,0,0,0"
                    Padding="6,6"
                    Background="#3A2020"
                    BorderBrush="#6A3030"
                    BorderThickness="1"
                    Foreground="{StaticResource TacticalCritical}"
                    FontWeight="Bold" FontSize="9"
                    Cursor="Hand"
                    Command="{Binding AbortKamikazeCommand}"
                    IsEnabled="{Binding IsKamikazeActive}"
                    ToolTip="Görevi iptal et — pull-up ve eve dönüş">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="StopCircle" Width="11" Height="11" VerticalAlignment="Center" />
                    <TextBlock Text="İPTAL" Margin="4,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </UniformGrid>
    </StackPanel>
</UserControl>
