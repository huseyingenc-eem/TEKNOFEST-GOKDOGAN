<UserControl x:Class="GOKDOGANIHA.UI.Controls.Sidebar.Panels.SafetyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="180">

    <UserControl.Resources>
        <!-- Renk LED satırı stili — diğer panellerle DRY tutarlılık. -->
        <Style x:Key="StatusRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="StatusValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StatusLabel" TargetType="TextBlock" BasedOn="{StaticResource MetricLabel}">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <!-- Sayaçlar SystemStatus alt ViewModel'inden güncellenir;
         renkler durum önem derecesine göre değişir. -->
    <StackPanel>
        <!-- Alan Sınırı -->
        <Grid Style="{StaticResource StatusRow}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="ALAN SINIRI"
                       Style="{StaticResource StatusLabel}" />
            <TextBlock Grid.Column="1">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValue}">
                        <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SystemStatus.IsInsideBoundary}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <TextBlock.Text>
                    <Binding Path="SystemStatus.DistanceToBoundaryEdge" StringFormat="İçeride · {0:F0} m" FallbackValue="— " />
                </TextBlock.Text>
            </TextBlock>
        </Grid>

        <!-- HSS İhlali -->
        <Grid Style="{StaticResource StatusRow}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="HSS İHLALİ"
                       Style="{StaticResource StatusLabel}" />
            <TextBlock Grid.Column="1">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValue}">
                        <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SystemStatus.HssViolationCount}" Value="0">
                                <Setter Property="Text" Value="Temiz · 0 s" />
                                <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0} ihlal · {1:F0} s">
                        <Binding Path="SystemStatus.HssViolationCount" />
                        <Binding Path="SystemStatus.HssViolationSeconds" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Grid>

        <!-- Manuel Geçiş -->
        <Grid Style="{StaticResource StatusRow}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="MANUEL GEÇİŞ"
                       Style="{StaticResource StatusLabel}" />
            <TextBlock Grid.Column="1" Style="{StaticResource StatusValue}"
                       Foreground="{StaticResource TacticalWarn}">
                <TextBlock.Text>
                    <Binding Path="SystemStatus.ManualTransitionCount" StringFormat="{}{0} kez" />
                </TextBlock.Text>
            </TextBlock>
        </Grid>

        <!-- Failsafe -->
        <Grid Style="{StaticResource StatusRow}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="FAILSAFE"
                       Style="{StaticResource StatusLabel}" />
            <TextBlock Grid.Column="1">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValue}">
                        <Setter Property="Text" Value="Hazır" />
                        <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SystemStatus.IsFailsafeActive}" Value="True">
                                <Setter Property="Text" Value="GCS Kayıp · RTL" />
                                <Setter Property="Foreground" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Telemetri Kopma -->
        <Grid Style="{StaticResource StatusRow}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="TELEMETRİ KOPMA"
                       Style="{StaticResource StatusLabel}" />
            <TextBlock Grid.Column="1" Style="{StaticResource StatusValue}"
                       Foreground="{StaticResource TacticalTextPrimary}">
                <TextBlock.Text>
                    <Binding Path="SystemStatus.CommDropoutCount" StringFormat="{}{0} kez" />
                </TextBlock.Text>
            </TextBlock>
        </Grid>
    </StackPanel>
</UserControl>
