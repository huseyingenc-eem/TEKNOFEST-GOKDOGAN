<UserControl x:Class="GOKDOGANIHA.UI.Controls.Sidebar.Panels.LockOnPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="220">

    <!-- DataContext = MainWindowViewModel.
         LockState: Idle/Tracking/Locking/Locked/Failed
         LockProgressSeconds: 0-4 sn, görsel progress -->
    <StackPanel>
        <!-- Durum kartı: LED + state + hedef ID — tek bir grup içinde, ferah padding -->
        <Border Background="{StaticResource TacticalGlass}"
                BorderBrush="{StaticResource TacticalOverlayBorder}"
                BorderThickness="1" CornerRadius="4"
                Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="12" Height="12" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource TacticalTextSecondary}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LockState}" Value="Tracking">
                                    <Setter Property="Fill" Value="{StaticResource TacticalAccent}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LockState}" Value="Locking">
                                    <Setter Property="Fill" Value="{StaticResource TacticalWarn}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LockState}" Value="Locked">
                                    <Setter Property="Fill" Value="{StaticResource TacticalOk}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LockState}" Value="Failed">
                                    <Setter Property="Fill" Value="{StaticResource TacticalCritical}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="DURUM" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding LockState}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TacticalTextPrimary}"
                               Margin="0,2,0,0" />
                </StackPanel>
                <Border Grid.Column="2"
                        Background="{StaticResource TacticalAccent}"
                        CornerRadius="3" Padding="8,4"
                        VerticalAlignment="Center">
                    <TextBlock FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                               Foreground="White"
                               Text="{Binding LockTargetId, StringFormat=T-{0:00}, TargetNullValue=—}" />
                </Border>
            </Grid>
        </Border>

        <!-- 4 saniyelik progress bar — renk LockState'e göre değişir -->
        <TextBlock Text="KİLİT İLERLEMESİ (4 SN)" Style="{StaticResource MetricLabel}"
                   Margin="0,0,0,4" />
        <Border Background="{StaticResource TacticalSurface}"
                BorderBrush="{StaticResource TacticalOverlayBorder}"
                BorderThickness="1" CornerRadius="3"
                Height="26" Margin="0,0,0,12">
            <Grid>
                <ProgressBar Minimum="0"
                             Maximum="{Binding LockRequiredSeconds}"
                             Value="{Binding LockProgressSeconds, Mode=OneWay}"
                             Background="Transparent"
                             BorderThickness="0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Foreground" Value="{StaticResource TacticalAccent}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LockState}" Value="Locking">
                                    <Setter Property="Foreground" Value="{StaticResource TacticalWarn}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LockState}" Value="Locked">
                                    <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LockState}" Value="Failed">
                                    <Setter Property="Foreground" Value="{StaticResource TacticalCritical}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
                <TextBlock Text="{Binding LockProgressText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                           Foreground="{StaticResource TacticalTextPrimary}" />
            </Grid>
        </Border>

        <!-- Detaylar -->
        <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="OTONOM"
                       Style="{StaticResource MetricLabel}" Margin="0,0,16,6"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="0" Grid.Column="1"
                       FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                       Margin="0,0,0,6">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="HAYIR" />
                        <Setter Property="Foreground" Value="{StaticResource TacticalTextSecondary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAutonomous}" Value="True">
                                <Setter Property="Text" Value="EVET ✓" />
                                <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="SON ACK"
                       Style="{StaticResource MetricLabel}" Margin="0,0,16,0"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding LastLockAck}"
                       FontFamily="Consolas" FontSize="13"
                       Foreground="{StaticResource TacticalTextPrimary}" />
        </Grid>

        <!-- Manuel paket gönder butonu — backend Faz 6'da, şimdilik UI hazır -->
        <Button Margin="0,14,0,0"
                Padding="14,10"
                Background="#3A2020"
                BorderBrush="#6A3030"
                BorderThickness="1"
                Foreground="{StaticResource TacticalCritical}"
                FontWeight="Bold" FontSize="12"
                Cursor="Hand"
                IsEnabled="{Binding IsConnected}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <materialIcons:MaterialIcon Kind="Send" Width="14" Height="14"
                                            VerticalAlignment="Center" />
                <TextBlock Text="KİLİTLENME PAKETİ GÖNDER"
                           Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>
