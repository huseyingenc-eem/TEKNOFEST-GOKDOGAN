<UserControl x:Class="GOKDOGANIHA.UI.Controls.Kamikaze.KamikazeFullscreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="800"
             Background="#0A1620">

    <UserControl.Resources>
        <!-- Panel başlık stili — DRY: APPROACH/OPTICAL/TERMINAL panellerinde paylaşılır -->
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TacticalAccent}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <!-- Metric tile stili (DISTANCE / VERTICAL VELOCITY) -->
        <Style x:Key="BigMetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TacticalTextSecondary}" />
        </Style>
        <Style x:Key="BigMetricValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TacticalAccent}" />
        </Style>
    </UserControl.Resources>

    <!-- DataContext = MainWindowViewModel -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Üst başlık + faz pills -->
            <RowDefinition Height="*" />      <!-- 2 panel ana alan -->
            <RowDefinition Height="Auto" />   <!-- Alt: ABORT butonu -->
        </Grid.RowDefinitions>

        <!-- ============== ÜST: TERMINAL PHASE BAŞLIK + 4 FAZ INDICATOR ============== -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <materialIcons:MaterialIcon Kind="Bomb" Width="22" Height="22"
                                            Foreground="{StaticResource TacticalCritical}"
                                            VerticalAlignment="Center" />
                <TextBlock Text="KAMİKAZE GÖREVİ"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
                <Border Background="{StaticResource TacticalCritical}"
                        CornerRadius="3" Padding="6,2"
                        Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="TERMINAL PHASE"
                               FontSize="9" FontWeight="Bold"
                               Foreground="White" />
                </Border>
            </StackPanel>

            <!-- 4 dot phase indicator: İNTİKAL · DALIŞ · QR · PAS GEÇ -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource BigMetricLabel}" Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding KamikazeStatus}" />
                <Border Width="8" Height="8" CornerRadius="4" Margin="2,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource TacticalSurface}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Intikal">
                                    <Setter Property="Background" Value="{StaticResource TacticalAccent}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Dalis"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="QrOkundu"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata"><Setter Property="Background" Value="{StaticResource TacticalCritical}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Width="8" Height="8" CornerRadius="4" Margin="2,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource TacticalSurface}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Dalis"><Setter Property="Background" Value="{StaticResource TacticalWarn}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="QrOkundu"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata"><Setter Property="Background" Value="{StaticResource TacticalCritical}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Width="8" Height="8" CornerRadius="4" Margin="2,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource TacticalSurface}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor"><Setter Property="Background" Value="{StaticResource TacticalAccent}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="QrOkundu"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata"><Setter Property="Background" Value="{StaticResource TacticalCritical}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Width="8" Height="8" CornerRadius="4" Margin="2,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource TacticalSurface}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="PasGec"><Setter Property="Background" Value="{StaticResource TacticalAccent}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Tamam"><Setter Property="Background" Value="{StaticResource TacticalOk}" /></DataTrigger>
                                <DataTrigger Binding="{Binding KamikazePhase}" Value="Hata"><Setter Property="Background" Value="{StaticResource TacticalCritical}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ============== ANA ALAN: 2 KOLON ============== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============ SOL: APPROACH GEOMETRY ============ -->
            <Border Grid.Column="0" Margin="0,0,8,0"
                    Background="#CC0A1620"
                    BorderBrush="{StaticResource TacticalOverlayBorder}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <materialIcons:MaterialIcon Kind="ChartBellCurveCumulative" Width="14" Height="14"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="APPROACH GEOMETRY" Style="{StaticResource PanelTitle}"
                                   Margin="6,0,0,10" />
                    </StackPanel>

                    <!-- SVG-tarzı yaklaşma yörüngesi.
                         Canvas 500x340 native — Viewbox uniform stretch ile panel alanına büyür.
                         Code-behind, FlightState'ten gelen Pitch ve Altitude değerlerine göre
                         drone ikonu Y konumunu ve bezier control noktalarını canlı set eder. -->
                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <Canvas Width="500" Height="340" x:Name="GeometryCanvas">
                            <!-- Yer çizgisi (sabit, alt) -->
                            <Line X1="40" Y1="280" X2="460" Y2="280"
                                  Stroke="#5A8AAA" StrokeThickness="1.5" Opacity="0.6" />
                            <Line X1="40" Y1="280" X2="40" Y2="290"  Stroke="#5A8AAA" StrokeThickness="1.5" Opacity="0.6" />
                            <Line X1="460" Y1="280" X2="460" Y2="290" Stroke="#5A8AAA" StrokeThickness="1.5" Opacity="0.6" />

                            <!-- Hedef noktası (dashed circle) -->
                            <Ellipse Canvas.Left="400" Canvas.Top="265" Width="22" Height="22"
                                     Stroke="#FFD700" StrokeThickness="2"
                                     StrokeDashArray="3,2" Fill="#33FFD700" />
                            <Ellipse Canvas.Left="408" Canvas.Top="273" Width="6" Height="6"
                                     Fill="#FFD700" />
                            <TextBlock Canvas.Left="395" Canvas.Top="295"
                                       Text="HEDEF" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                       Foreground="#FFD700" />

                            <!-- Yaklaşma yörüngesi — bezier eğrisi.
                                 PathFigure'in StartPoint ve BezierSegment'i code-behind'de canlı güncellenir
                                 (drone Y konumu + bezier control noktaları).
                                 Renk gradient: cyan (yüksek) → yellow → red (alçak/dalış sonu). -->
                            <Path x:Name="ApproachCurve" StrokeThickness="3" StrokeLineJoin="Round">
                                <Path.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00D1C7" Offset="0" />
                                        <GradientStop Color="#FFD700" Offset="0.6" />
                                        <GradientStop Color="#FF5252" Offset="1" />
                                    </LinearGradientBrush>
                                </Path.Stroke>
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure x:Name="ApproachStart" StartPoint="80,80">
                                            <BezierSegment x:Name="ApproachBezier"
                                                Point1="180,100" Point2="300,180" Point3="411,276" />
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>

                            <!-- İHA ikonu — Canvas.Left/Top code-behind'de FlightState'ten set edilir -->
                            <Path x:Name="DroneIcon"
                                  Data="M 0,8 L 16,0 L 0,-8 L 4,0 Z"
                                  Fill="{StaticResource TacticalAccent}"
                                  Canvas.Left="80" Canvas.Top="80">
                                <Path.Effect>
                                    <DropShadowEffect Color="#00D1C7" BlurRadius="10"
                                                      ShadowDepth="0" Opacity="0.7" />
                                </Path.Effect>
                            </Path>
                        </Canvas>
                    </Viewbox>

                    <!-- Sağ-üstte mevcut metrikler — okunaklı -->
                    <Border Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#B30A1620"
                            BorderBrush="{StaticResource TacticalOverlayBorder}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="10,8" Margin="0,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ALT_CUR" Style="{StaticResource BigMetricLabel}" Margin="0,0,12,2" />
                            <TextBlock Grid.Row="0" Grid.Column="1" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource TacticalAccent}">
                                <TextBlock.Text><Binding Path="Altitude" StringFormat="{}{0:0} m" FallbackValue="— m" /></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ALT_TGT" Style="{StaticResource BigMetricLabel}" Margin="0,2,12,2" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="30 m"
                                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource TacticalWarn}" Margin="0,2,0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="ANGLE" Style="{StaticResource BigMetricLabel}" Margin="0,2,12,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource TacticalCritical}">
                                <TextBlock.Text><Binding Path="Pitch" StringFormat="{}{0:0}°" FallbackValue="—°" /></TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ============ SAĞ: OPTICAL TARGETING ============ -->
            <Border Grid.Column="1" Margin="8,0,0,0"
                    Background="#CC0A1620"
                    BorderBrush="{StaticResource TacticalOverlayBorder}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />     <!-- Başlık -->
                        <RowDefinition Height="*" />        <!-- Kamera + QR overlay -->
                        <RowDefinition Height="Auto" />     <!-- Distance/V-S metrics -->
                        <RowDefinition Height="Auto" />     <!-- Decoder status -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <materialIcons:MaterialIcon Kind="Crosshairs" Width="14" Height="14"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="OPTICAL TARGETING" Style="{StaticResource PanelTitle}"
                                   Margin="6,0,0,10" />
                    </StackPanel>

                    <!-- Kamera placeholder + QR detection rect overlay (mockup gibi sarı) -->
                    <Border Grid.Row="1" Background="#11FFFFFF"
                            BorderBrush="{StaticResource TacticalOverlayBorder}"
                            BorderThickness="1" CornerRadius="4"
                            Margin="0,0,0,10">
                        <Grid>
                            <TextBlock Text="— CANLI KAMERA AKIŞI —"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#55FFFFFF"
                                       FontFamily="Consolas" FontSize="13" />

                            <!-- Crosshair sabit -->
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="180" Height="180" IsHitTestVisible="False" Opacity="0.4">
                                <Ellipse Stroke="{StaticResource TacticalAccent}" StrokeThickness="1"
                                         Width="40" Height="40" />
                                <Line X1="90" Y1="40" X2="90" Y2="80"  Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                                <Line X1="90" Y1="100" X2="90" Y2="140" Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                                <Line X1="40" Y1="90" X2="80" Y2="90"   Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                                <Line X1="100" Y1="90" X2="140" Y2="90" Stroke="{StaticResource TacticalAccent}" StrokeThickness="1.5" />
                            </Grid>

                            <!-- QR detection rectangle — mockup'taki sarı dörtgen, QR fazında görünür -->
                            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Width="120" Height="120"
                                    BorderBrush="#FFD700" BorderThickness="3"
                                    Background="#22FFD700"
                                    Visibility="Collapsed">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrOkundu">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="BorderBrush" Value="{StaticResource TacticalOk}" />
                                                <Setter Property="Background" Value="#3300FF66" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <!-- 4 köşe vurgusu — modern QR scanner UI -->
                                    <Border BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Border}}"
                                            BorderThickness="3,3,0,0" Width="20" Height="20"
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-3,-3,0,0" />
                                    <Border BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Border}}"
                                            BorderThickness="0,3,3,0" Width="20" Height="20"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0" />
                                    <Border BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Border}}"
                                            BorderThickness="3,0,0,3" Width="20" Height="20"
                                            HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-3,0,0,-3" />
                                    <Border BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Border}}"
                                            BorderThickness="0,0,3,3" Width="20" Height="20"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- DISTANCE TO TARGET + VERTICAL VELOCITY (mockup'taki büyük metric tile'lar) -->
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="0,0,4,0"
                                Background="#330A1620"
                                BorderBrush="{StaticResource TacticalOverlayBorder}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="DISTANCE TO TARGET" Style="{StaticResource BigMetricLabel}" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="DistanceText" Style="{StaticResource BigMetricValue}" Text="—" />
                                    <TextBlock Text="m" FontSize="12" VerticalAlignment="Bottom"
                                               Foreground="{StaticResource TacticalTextSecondary}"
                                               Margin="6,0,0,6" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="4,0,0,0"
                                Background="#330A1620"
                                BorderBrush="{StaticResource TacticalOverlayBorder}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="VERTICAL VELOCITY" Style="{StaticResource BigMetricLabel}" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Style="{StaticResource BigMetricValue}"
                                               Foreground="{StaticResource TacticalCritical}">
                                        <TextBlock.Text>
                                            <Binding Path="VerticalSpeed" StringFormat="{}{0:0}" FallbackValue="—" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="m/s" FontSize="12" VerticalAlignment="Bottom"
                                               Foreground="{StaticResource TacticalTextSecondary}"
                                               Margin="6,0,0,6" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- DECODER STATUS + QR Metni (mockup'taki teknik bilgi satırı) -->
                    <Border Grid.Row="3"
                            Background="#22000000"
                            BorderBrush="{StaticResource TacticalOverlayBorder}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="10,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialIcons:MaterialIcon Kind="Sync" Width="11" Height="11"
                                                            Foreground="{StaticResource TacticalAccent}"
                                                            VerticalAlignment="Center" />
                                <TextBlock Text="DECODER STATUS"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource TacticalTextSecondary}"
                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="(cv2.warpPerspective)"
                                           FontFamily="Consolas" FontSize="9"
                                           Foreground="{StaticResource TacticalTextSecondary}"
                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Margin="0,4,0,0"
                                       FontFamily="Consolas" FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="QR Metni: {0}" FallbackValue="QR Metni: —">
                                        <Binding Path="KamikazeQrText" TargetNullValue="—" FallbackValue="—" />
                                    </MultiBinding>
                                </TextBlock.Text>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TacticalTextPrimary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KamikazePhase}" Value="QrAriyor">
                                                <Setter Property="Foreground" Value="{StaticResource TacticalWarn}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding KamikazeQrText}" Value="">
                                                <Setter Property="Foreground" Value="{StaticResource TacticalTextSecondary}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ============== ALT: ABORT KAMİKAZE BÜYÜK BUTON ============== -->
        <Button Grid.Row="2" Margin="0,16,0,0"
                Padding="20,16"
                Background="#3A0A0A"
                BorderBrush="{StaticResource TacticalCritical}"
                BorderThickness="2"
                Foreground="{StaticResource TacticalCritical}"
                FontSize="18" FontWeight="Bold"
                Cursor="Hand"
                Command="{Binding AbortKamikazeCommand}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <materialIcons:MaterialIcon Kind="AlertOctagon" Width="22" Height="22"
                                            VerticalAlignment="Center" />
                <TextBlock Text="ABORT KAMİKAZE" Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
