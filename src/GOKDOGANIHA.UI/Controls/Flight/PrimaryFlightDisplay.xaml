<UserControl x:Class="GOKDOGANIHA.UI.Controls.Flight.PrimaryFlightDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Self"
             mc:Ignorable="d"
             Width="280" Height="180"
             IsHitTestVisible="False">

    <UserControl.Resources>
        <!-- Tape ortak text stili — DRY (speed + altitude tape paylaşır) -->
        <Style x:Key="TapeText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="#99E6ECF2" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <!-- Glass kart — şeffaf koyu zemin, ince border, drop shadow. Tasarım: minimal + tactical. -->
    <Border Background="#CC0A1620"
            BorderBrush="{StaticResource TacticalOverlayBorder}"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="3" BlurRadius="12" Opacity="0.5" />
        </Border.Effect>

        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42" />   <!-- Speed tape -->
                <ColumnDefinition Width="*" />    <!-- Attitude indicator -->
                <ColumnDefinition Width="42" />   <!-- Altitude tape -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="22" />     <!-- Heading strip -->
            </Grid.RowDefinitions>

            <!-- ============ SPEED TAPE (sol şerit) ============ -->
            <Border Grid.Column="0" Grid.Row="0"
                    Background="#33000000"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <TextBlock Text="m/s" Style="{StaticResource TapeText}"
                               VerticalAlignment="Top" Margin="0,2,0,0" />
                    <Border Background="{StaticResource TacticalAccent}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center" Height="22">
                        <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="Airspeed" ElementName="Self"
                                         StringFormat="{}{0:0}" FallbackValue="0" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="IAS" Style="{StaticResource TapeText}"
                               VerticalAlignment="Bottom" Margin="0,0,0,2"
                               Foreground="{StaticResource TacticalAccent}" />
                </Grid>
            </Border>

            <!-- ============ ATTITUDE INDICATOR (orta yapay ufuk) ============ -->
            <Grid Grid.Column="1" Grid.Row="0" ClipToBounds="True">
                <!-- Roll: outer rotation (tüm horizon Roll açısıyla döner).
                     Pitch: inner translate (Y kayar, code-behind'de 1.8x ölçeklenir).
                     Transform'lar code-behind'de PitchProperty/RollProperty Changed callback ile set edilir. -->
                <Grid x:Name="RollGroup" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="RollTransform" Angle="0" />
                    </Grid.RenderTransform>

                    <Canvas x:Name="HorizonCanvas" Width="178" Height="136"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas.RenderTransform>
                            <TranslateTransform x:Name="PitchTransform" Y="0" />
                        </Canvas.RenderTransform>

                        <!-- Sky (üst yarı) -->
                        <Rectangle Canvas.Left="-100" Canvas.Top="-200" Width="378" Height="268">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#3A6080" Offset="0" />
                                    <GradientStop Color="#5A8AAA" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Ground (alt yarı) -->
                        <Rectangle Canvas.Left="-100" Canvas.Top="68" Width="378" Height="268">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#6A5030" Offset="0" />
                                    <GradientStop Color="#3E2E18" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Horizon line -->
                        <Line X1="-100" Y1="68" X2="278" Y2="68"
                              Stroke="White" StrokeThickness="1.5" Opacity="0.85" />

                        <!-- Pitch ladder — 10°/20° işaretleri (1° ≈ 1.8 px) -->
                        <Line X1="59" Y1="32" X2="119" Y2="32" Stroke="White" StrokeThickness="0.8" Opacity="0.6" />
                        <TextBlock Canvas.Left="123" Canvas.Top="26" Text="+20" Foreground="White" Opacity="0.7" FontSize="8" FontFamily="Consolas" />
                        <Line X1="69" Y1="50" X2="109" Y2="50" Stroke="White" StrokeThickness="0.8" Opacity="0.6" />
                        <TextBlock Canvas.Left="113" Canvas.Top="44" Text="+10" Foreground="White" Opacity="0.7" FontSize="8" FontFamily="Consolas" />
                        <Line X1="69" Y1="86" X2="109" Y2="86" Stroke="White" StrokeThickness="0.8" Opacity="0.6" />
                        <TextBlock Canvas.Left="113" Canvas.Top="80" Text="-10" Foreground="White" Opacity="0.7" FontSize="8" FontFamily="Consolas" />
                        <Line X1="59" Y1="104" X2="119" Y2="104" Stroke="White" StrokeThickness="0.8" Opacity="0.6" />
                        <TextBlock Canvas.Left="123" Canvas.Top="98" Text="-20" Foreground="White" Opacity="0.7" FontSize="8" FontFamily="Consolas" />
                    </Canvas>
                </Grid>

                <!-- Aircraft reference symbol — rotate ETMEZ (uçak hep dümdüz görünür).
                     Canvas Width=178 + HorizontalAlignment=Center → HorizonCanvas ile aynı
                     hizada, içindeki x koordinatları center=89 referansıyla simetrik. -->
                <Canvas Width="178" Height="136"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsHitTestVisible="False">
                    <Line X1="50"  Y1="68" X2="78"  Y2="68"
                          Stroke="{StaticResource TacticalWarn}" StrokeThickness="2.5" />
                    <Line X1="78"  Y1="68" X2="78"  Y2="73"
                          Stroke="{StaticResource TacticalWarn}" StrokeThickness="2" />
                    <Ellipse Canvas.Left="84" Canvas.Top="63" Width="10" Height="10"
                             Stroke="{StaticResource TacticalWarn}" StrokeThickness="1.5" Fill="Transparent" />
                    <Line X1="100" Y1="68" X2="100" Y2="73"
                          Stroke="{StaticResource TacticalWarn}" StrokeThickness="2" />
                    <Line X1="100" Y1="68" X2="128" Y2="68"
                          Stroke="{StaticResource TacticalWarn}" StrokeThickness="2.5" />
                </Canvas>
            </Grid>

            <!-- ============ ALTITUDE TAPE (sağ şerit) ============ -->
            <Border Grid.Column="2" Grid.Row="0"
                    Background="#33000000"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <TextBlock Text="m" Style="{StaticResource TapeText}"
                               VerticalAlignment="Top" Margin="0,2,0,0" />
                    <Border Background="{StaticResource TacticalOk}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center" Height="22">
                        <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="Altitude" ElementName="Self"
                                         StringFormat="{}{0:0}" FallbackValue="0" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <!-- V/S sub-readout — code-behind callback rengi günceller (yeşil/sarı) -->
                    <TextBlock x:Name="VerticalSpeedText" Style="{StaticResource TapeText}"
                               VerticalAlignment="Bottom" Margin="0,0,0,2"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TacticalOk}">
                        <TextBlock.Text>
                            <Binding Path="VerticalSpeed" ElementName="Self"
                                     StringFormat="V/S {0:+0.0;-0.0;0.0}" FallbackValue="V/S 0.0" />
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ============ HEADING COMPASS STRIP (alt) ============ -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                    Background="#22000000"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,1,0,0"
                    Margin="0,2,0,0">
                <Grid>
                    <TextBlock FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource TacticalAccent}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="Heading" ElementName="Self"
                                     StringFormat="HDG {0:000}°" FallbackValue="HDG 000°" />
                        </TextBlock.Text>
                    </TextBlock>
                    <Path Data="M 0,4 L 5,0 L 10,4 Z"
                          Fill="{StaticResource TacticalAccent}"
                          HorizontalAlignment="Center" VerticalAlignment="Top"
                          Margin="0,1,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
