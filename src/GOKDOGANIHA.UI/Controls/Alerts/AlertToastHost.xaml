<UserControl x:Class="GOKDOGANIHA.UI.Controls.Alerts.AlertToastHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="200"
             IsHitTestVisible="False">

    <UserControl.Resources>
        <!-- Toast item template — alert level'a göre ikon ve renk -->
        <DataTemplate x:Key="ToastItemTemplate">
            <Border Margin="0,0,0,8"
                    CornerRadius="6" Padding="10,8"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <!-- default: Info — accent -->
                        <Setter Property="Background" Value="#E60A1620" />
                        <Setter Property="BorderBrush" Value="{StaticResource TacticalAccent}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Level}" Value="Warn">
                                <Setter Property="Background" Value="#E62A1A0A" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalWarn}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="Danger">
                                <Setter Property="Background" Value="#E62A0A0A" />
                                <Setter Property="BorderBrush" Value="{StaticResource TacticalCritical}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270"
                                      ShadowDepth="3" BlurRadius="14" Opacity="0.5" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <materialIcons:MaterialIcon Grid.Column="0" Width="18" Height="18"
                                                VerticalAlignment="Top" Margin="0,2,0,0">
                        <materialIcons:MaterialIcon.Style>
                            <Style TargetType="materialIcons:MaterialIcon">
                                <Setter Property="Kind" Value="InformationOutline" />
                                <Setter Property="Foreground" Value="{StaticResource TacticalAccent}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Level}" Value="Warn">
                                        <Setter Property="Kind" Value="AlertOutline" />
                                        <Setter Property="Foreground" Value="{StaticResource TacticalWarn}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="Danger">
                                        <Setter Property="Kind" Value="AlertOctagon" />
                                        <Setter Property="Foreground" Value="{StaticResource TacticalCritical}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialIcons:MaterialIcon.Style>
                    </materialIcons:MaterialIcon>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Text="{Binding Message}"
                                   FontSize="10"
                                   Foreground="#CCFFFFFF"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ItemsControl x:Name="ToastList" Width="320"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  ItemTemplate="{StaticResource ToastItemTemplate}" />
</UserControl>
