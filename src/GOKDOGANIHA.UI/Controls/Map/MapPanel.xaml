<UserControl x:Class="GOKDOGANIHA.UI.Controls.Map.MapPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:ui="clr-namespace:GOKDOGANIHA.UI"
             mc:Ignorable="d"
             d:DesignWidth="1600" d:DesignHeight="900">

    <UserControl.Resources>
        <Style x:Key="MapNavButton" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource TacticalGlass}" />
            <Setter Property="BorderBrush" Value="{StaticResource TacticalOverlayBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Real tile map (default: Stadia Alidade Smooth Dark) -->
        <gmap:GMapControl x:Name="MapCtrl" />

        <!-- Very light tint — Stadia's dark basemap is already muted,
             a heavy tint would wash it out. -->
        <Rectangle Fill="#20061018" IsHitTestVisible="False" />

        <!-- İsteğe bağlı taktik grid. MapOptions.ShowGrid ile yönetilir. -->
        <Rectangle x:Name="GridOverlay" IsHitTestVisible="False" Opacity="0.16">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,72,72"
                              ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Pen>
                                <Pen Brush="{StaticResource TacticalAccent}" Thickness="0.6" />
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="0,0" EndPoint="72,0" />
                                    <LineGeometry StartPoint="0,0" EndPoint="0,72" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Harita navigasyonu -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,80,16,0">
            <Button Style="{StaticResource MapNavButton}" ToolTip="Yakınlaştır"
                    Click="OnZoomInClick">
                <materialIcons:MaterialIcon Kind="Plus" Width="18" Height="18" />
            </Button>
            <Button Style="{StaticResource MapNavButton}" ToolTip="Uzaklaştır"
                    Click="OnZoomOutClick">
                <materialIcons:MaterialIcon Kind="Minus" Width="18" Height="18" />
            </Button>
            <Button Style="{StaticResource MapNavButton}" ToolTip="Kendi İHA'ma git"
                    Click="OnCenterOwnClick">
                <materialIcons:MaterialIcon Kind="CrosshairsGps" Width="18" Height="18" />
            </Button>
            <ToggleButton Width="38" Height="38"
                          Padding="0"
                          Background="{StaticResource TacticalGlass}"
                          BorderBrush="{StaticResource TacticalOverlayBorder}"
                          BorderThickness="1"
                          IsChecked="{Binding FollowOwnship, Mode=TwoWay}"
                          ToolTip="İHA'yı otomatik takip et">
                <materialIcons:MaterialIcon Kind="NavigationVariant" Width="18" Height="18" />
            </ToggleButton>
            <Button Style="{StaticResource MapNavButton}" Margin="0,6,0,0"
                    ToolTip="Yarışma alanını göster"
                    Click="OnFitBoundaryClick">
                <materialIcons:MaterialIcon Kind="MapMarkerRadius" Width="18" Height="18" />
            </Button>
        </StackPanel>

        <!-- ============== ÇİZİM MODU AKTİF ROZETİ (sol-orta üstü) ============== -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,118,0,0"
                Background="#D9D68910"
                BorderBrush="{StaticResource TacticalWarn}"
                BorderThickness="1"
                CornerRadius="3"
                Padding="10,4"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrawingPolygon}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <materialIcons:MaterialIcon Kind="CursorDefaultClickOutline"
                                            Width="13" Height="13"
                                            Foreground="White"
                                            VerticalAlignment="Center" />
                <TextBlock Text="ÇİZİM MODU"
                           FontSize="11" FontWeight="Bold"
                           Foreground="White"
                           Margin="6,0,8,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="sol tık vertex · sağ tık tamamla"
                           FontSize="10"
                           Foreground="White" Opacity="0.85"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Attribution (required by Stadia + OSM ODbL) -->
        <TextBlock Text="© Stadia Maps  © OpenStreetMap contributors"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,8,6"
                   FontSize="9"
                   Foreground="#99E6ECF2"
                   IsHitTestVisible="False" />

        <!-- İmleç koordinatı ve katman özeti -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,14"
                Padding="10,5"
                CornerRadius="4"
                Background="{StaticResource TacticalGlass}"
                BorderBrush="{StaticResource TacticalOverlayBorder}"
                BorderThickness="1"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding CursorLatitude, StringFormat={}{0:F6}}"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TacticalTextPrimary}" />
                <TextBlock Text="  /  " FontSize="10"
                           Foreground="{StaticResource TacticalTextSecondary}" />
                <TextBlock Text="{Binding CursorLongitude, StringFormat={}{0:F6}}"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TacticalTextPrimary}" />
                <TextBlock Text="   ·   RAKİP "
                           Margin="8,0,0,0" FontSize="10"
                           Foreground="{StaticResource TacticalTextSecondary}" />
                <TextBlock Text="{Binding EnemyDrones.Count}"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TacticalCritical}" />
                <TextBlock Text="   ·   HSS "
                           FontSize="10"
                           Foreground="{StaticResource TacticalTextSecondary}" />
                <TextBlock Text="{Binding HssZones.Count}"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TacticalWarn}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
