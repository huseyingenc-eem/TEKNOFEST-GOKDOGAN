<UserControl x:Class="GOKDOGANIHA.UI.Controls.Map.MapPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
             mc:Ignorable="d"
             d:DesignWidth="1600" d:DesignHeight="900">

    <Grid>
        <!-- Real tile map -->
        <gmap:GMapControl x:Name="MapCtrl" />

        <!-- Tactical dark tint so overlays stay legible over bright OSM tiles -->
        <Rectangle Fill="#55061018" IsHitTestVisible="False" />
    </Grid>
</UserControl>
