<Window x:Class="GOKDOGANIHA.UI.Views.SafetyConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        Width="520" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{StaticResource TacticalGlassStrong}"
            BorderBrush="{StaticResource TacticalWarn}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="22">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="8" BlurRadius="32" Opacity="0.8" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border Width="36" Height="36" CornerRadius="18"
                        Background="#33FFB300">
                    <materialIcons:MaterialIcon Kind="AlertOutline"
                                                Width="21" Height="21"
                                                Foreground="{StaticResource TacticalWarn}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="TitleText"
                           Margin="12,0,0,0"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TacticalTextPrimary}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Margin="48,18,0,22"
                       FontSize="12"
                       LineHeight="19"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TacticalTextSecondary}" />

            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="NoButton"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        MinWidth="100" Padding="16,8"
                        IsDefault="True"
                        IsCancel="True"
                        Click="OnNoClick" />
                <Button x:Name="YesButton"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        MinWidth="130" Padding="16,8"
                        Margin="10,0,0,0"
                        Click="OnYesClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
