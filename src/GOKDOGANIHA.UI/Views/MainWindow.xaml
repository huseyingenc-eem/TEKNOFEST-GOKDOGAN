<Window x:Class="GOKDOGANIHA.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:GOKDOGANIHA.UI.ViewModels"
        xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
        xmlns:shell="clr-namespace:GOKDOGANIHA.UI.Controls.Shell"
        xmlns:map="clr-namespace:GOKDOGANIHA.UI.Controls.Map"
        xmlns:video="clr-namespace:GOKDOGANIHA.UI.Controls.Video"
        xmlns:telemetry="clr-namespace:GOKDOGANIHA.UI.Controls.Telemetry"
        xmlns:sidebar="clr-namespace:GOKDOGANIHA.UI.Controls.Sidebar"
        xmlns:views="clr-namespace:GOKDOGANIHA.UI.Views"
        mc:Ignorable="d"
        Title="GÖKDOĞAN — Yer Kontrol İstasyonu"
        Height="1080" Width="1920"
        MinHeight="900" MinWidth="1600"
        Background="{StaticResource TacticalBgDeep}"
        TextElement.Foreground="{StaticResource TacticalTextPrimary}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="13"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <!-- 2-kolon: harita arka plan + sağ accordion sidebar.
         Fullscreen overlay'ler (Camera, Settings) ColumnSpan=2 ile her iki kolonu kaplar. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <!-- ============ HARİTA KOLONU + OVERLAY'LER ============ -->
        <Grid Grid.Column="0">
            <map:MapPanel DataContext="{Binding MapVm}" />

            <!-- Top: status bar (sunucu saati + status pills) -->
            <shell:TopBar VerticalAlignment="Top" />

            <!-- Top-LEFT overlay: HUD-tarzı kompakt telemetri kartı (tıkla → büyüt) -->
            <telemetry:TelemetryPanel
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Width="280"
                Margin="16,78,0,0"
                IsExpanded="{Binding IsTelemetryExpanded, Mode=TwoWay}" />

            <!-- Top-right (harita kolonu içinde): video panel — kilit dörtgeni overlay buradan -->
            <video:VideoPanel
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Width="400" Height="280"
                Margin="0,78,16,0" />

            <!-- Bottom-left: Flight dial (ARM/OTONOM/RTL/İNİŞ) — fans up-right -->
            <core:RadialMenu
                x:Name="FlightDial"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Margin="-148,0,0,-148"
                Radius="170" ItemSize="60"
                StartAngle="270" SweepAngle="90"
                TriggerIconKind="AirplaneTakeoff"
                TriggerIconWhenOpenKind="Close">
                <core:RadialMenuItem IconKind="ShieldCheck"     Label="ARM"    Variant="Ok"      IconBrush="{StaticResource TacticalOk}" />
                <core:RadialMenuItem IconKind="Robot"           Label="OTONOM" Variant="Primary" IconBrush="{StaticResource TacticalAccent}" />
                <core:RadialMenuItem IconKind="HomeMapMarker"   Label="RTL"    Variant="Warn"    IconBrush="{StaticResource TacticalWarn}" />
                <core:RadialMenuItem IconKind="AirplaneLanding" Label="İNİŞ"   Variant="Primary" IconBrush="{StaticResource TacticalAccent}" />
            </core:RadialMenu>

            <!-- Bottom-right (harita kolonunun sağ alt köşesi): Attack dial — fans up-left -->
            <core:RadialMenu
                x:Name="AttackDial"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,-148,-148"
                Radius="170" ItemSize="60"
                StartAngle="180" SweepAngle="90"
                TriggerIconKind="TargetAccount"
                TriggerIconWhenOpenKind="Close">
                <core:RadialMenuItem IconKind="Crosshairs" Label="KİLİTLE"  Variant="Primary" IconBrush="{StaticResource TacticalAccent}" />
                <core:RadialMenuItem IconKind="Bomb"       Label="KAMİKAZE" Variant="Danger"  IconBrush="{StaticResource TacticalCritical}" />
                <core:RadialMenuItem IconKind="Cancel"     Label="İPTAL"    Variant="Warn"    IconBrush="{StaticResource TacticalWarn}" />
            </core:RadialMenu>
        </Grid>

        <!-- ============ SAĞ KOLON: Accordion paneller ============ -->
        <sidebar:RightSidebar Grid.Column="1" />

        <!-- ============ FULLSCREEN OVERLAY'LER (tüm window'u kaplar) ============ -->
        <core:OverlayHost Grid.Column="0" Grid.ColumnSpan="2"
                          IsOpen="{Binding IsCameraFullscreen, Mode=TwoWay}"
                          Title="GÖREV KAMERASI"
                          Subtitle="Tam ekran · ESC veya arka plana tıklayarak kapat"
                          HeaderIconKind="Video"
                          ContentMargin="0,60,0,0">
            <video:CameraFullscreenView />
        </core:OverlayHost>

        <core:OverlayHost Grid.Column="0" Grid.ColumnSpan="2"
                          IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
                          Title="AYARLAR"
                          Subtitle="GÖKDOĞAN YKİ yapılandırması"
                          HeaderIconKind="Cog"
                          ContentMargin="0,60,0,0">
            <views:SettingsView DataContext="{Binding Settings}" />
        </core:OverlayHost>
    </Grid>
</Window>
