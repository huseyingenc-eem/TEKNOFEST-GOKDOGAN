<Window x:Class="GOKDOGANIHA.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:ui="clr-namespace:GOKDOGANIHA.UI"
        xmlns:vm="clr-namespace:GOKDOGANIHA.UI.ViewModels"
        xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
        xmlns:shell="clr-namespace:GOKDOGANIHA.UI.Controls.Shell"
        xmlns:map="clr-namespace:GOKDOGANIHA.UI.Controls.Map"
        xmlns:video="clr-namespace:GOKDOGANIHA.UI.Controls.Video"
        xmlns:telemetry="clr-namespace:GOKDOGANIHA.UI.Controls.Telemetry"
        xmlns:sidebar="clr-namespace:GOKDOGANIHA.UI.Controls.Sidebar"
        xmlns:kamikaze="clr-namespace:GOKDOGANIHA.UI.Controls.Kamikaze"
        xmlns:alerts="clr-namespace:GOKDOGANIHA.UI.Controls.Alerts"
        xmlns:views="clr-namespace:GOKDOGANIHA.UI.Views"
        mc:Ignorable="d"
        Title="GÖKDOĞAN — Yer Kontrol İstasyonu"
        Height="1080" Width="1920"
        MinHeight="900" MinWidth="1600"
        Background="{StaticResource TacticalBgDeep}"
        TextElement.Foreground="{StaticResource TacticalTextPrimary}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="13"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <!-- 2-kolon: harita arka plan + sağ accordion sidebar.
         Fullscreen overlay'ler (Camera, Settings) ColumnSpan=2 ile her iki kolonu kaplar. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <!-- ============ HARİTA KOLONU + OVERLAY'LER ============ -->
        <Grid Grid.Column="0">
            <map:MapPanel DataContext="{Binding MapVm}" />

            <!-- Top: status bar (sunucu saati + status pills) -->
            <shell:TopBar VerticalAlignment="Top" />

            <!-- Top-LEFT overlay: HUD-tarzı kompakt telemetri kartı (tıkla → büyüt) -->
            <telemetry:TelemetryPanel
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Width="280"
                Margin="16,78,0,0"
                IsExpanded="{Binding IsTelemetryExpanded, Mode=TwoWay}" />

            <!-- Top-right (harita kolonu içinde): video panel — kilit dörtgeni overlay buradan -->
            <video:VideoPanel
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Width="400" Height="280"
                Margin="0,78,16,0">
                <video:VideoPanel.Style>
                    <Style TargetType="{x:Type video:VideoPanel}">
                        <Setter Property="Visibility" Value="Visible" />
                        <!-- LibVLC native/airspace yüzeyi WPF Z-order'ini izlemez.
                             Overlay açıkken küçük yüzeyi gerçekten gizle; paylaşılan
                             oynatıcı arka planda akışı kesmeden devam eder. -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnyOverlayOpen}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </video:VideoPanel.Style>
            </video:VideoPanel>

            <!-- Bottom-left: Flight dial (ARM/OTONOM/RTL/İNİŞ) — fans up-right -->
            <core:RadialMenu
                x:Name="FlightDial"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Margin="-148,0,0,-148"
                Radius="170" ItemSize="60"
                StartAngle="270" SweepAngle="90"
                TriggerIconKind="AirplaneTakeoff"
                TriggerIconWhenOpenKind="Close">
                <core:RadialMenuItem IconKind="ShieldCheck"     Label="ARM"    Variant="Ok"      IconBrush="{StaticResource TacticalOk}" />
                <core:RadialMenuItem IconKind="Robot"           Label="OTONOM" Variant="Primary" IconBrush="{StaticResource TacticalAccent}" />
                <core:RadialMenuItem IconKind="HomeMapMarker"   Label="RTL"    Variant="Warn"    IconBrush="{StaticResource TacticalWarn}" />
                <core:RadialMenuItem IconKind="AirplaneLanding" Label="İNİŞ"   Variant="Primary" IconBrush="{StaticResource TacticalAccent}" />
            </core:RadialMenu>

            <!-- Bottom-right (harita kolonunun sağ alt köşesi): Attack dial — fans up-left -->
            <core:RadialMenu
                x:Name="AttackDial"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,-148,-148"
                Radius="170" ItemSize="60"
                StartAngle="180" SweepAngle="90"
                TriggerIconKind="TargetAccount"
                TriggerIconWhenOpenKind="Close">
                <core:RadialMenuItem IconKind="Crosshairs" Label="KİLİTLE"  Variant="Primary" IconBrush="{StaticResource TacticalAccent}" />
                <core:RadialMenuItem IconKind="Bomb"       Label="KAMİKAZE" Variant="Danger"  IconBrush="{StaticResource TacticalCritical}" />
                <core:RadialMenuItem IconKind="Cancel"     Label="İPTAL"    Variant="Warn"    IconBrush="{StaticResource TacticalWarn}" />
            </core:RadialMenu>

            <!-- HARİTA AYAR FAB — RadialMenu'lardan SONRA tanımlandı, Z-order üstte
                 (aynı parent Grid'de sonradan eklenen daha üstte). RadialMenu trigger
                 dışındaki transparent alan tıklamaları yutuyordu, bu yüzden burada. -->
            <ToggleButton x:Name="MapMenuToggle"
                          HorizontalAlignment="Right" VerticalAlignment="Bottom"
                          Margin="0,0,16,16"
                          Width="48" Height="48"
                          Background="{StaticResource TacticalGlass}"
                          BorderBrush="{StaticResource TacticalOverlayBorder}"
                          BorderThickness="1"
                          Cursor="Hand"
                          ToolTip="Harita ayarları (çizim · iz · katmanlar)"
                          Click="OnMapMenuClick">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270"
                                                  ShadowDepth="3" BlurRadius="12" Opacity="0.5" />
                            </Border.Effect>
                            <materialIcons:MaterialIcon Kind="LayersTriple"
                                                        Width="22" Height="22"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Foreground="{StaticResource TacticalTextPrimary}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource TacticalAccent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource TacticalAccent}" />
                                <Setter TargetName="Bd" Property="Background" Value="#330A1620" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>

            <!-- Popover — code-behind butonun pencere konumuna göre Placement ayarlar
                 (Top/Bottom). DataContext = MainWindowViewModel (default) → MapVm.X
                 ile commands; App.AppOptions ise iç StackPanel'da x:Static ile. -->
            <Popup x:Name="MapMenuPopup"
                   IsOpen="{Binding IsChecked, ElementName=MapMenuToggle, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=MapMenuToggle}"
                   Placement="Top"
                   HorizontalOffset="-240"
                   VerticalOffset="-6"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   StaysOpen="False">
                <Border Background="{StaticResource TacticalGlass}"
                        BorderBrush="{StaticResource TacticalOverlayBorder}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="14" Width="280">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270"
                                          ShadowDepth="4" BlurRadius="20" Opacity="0.6" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialIcons:MaterialIcon Kind="MapMarkerRadius" Width="15" Height="15"
                                                        Foreground="{StaticResource TacticalAccent}"
                                                        VerticalAlignment="Center" />
                            <TextBlock Text="HARİTA AYARLARI"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TacticalTextPrimary}"
                                       Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- ARAÇLAR — MainWindow DataContext = MainWindowViewModel,
                             MapVm.X commands kullanılıyor -->
                        <TextBlock Text="ARAÇLAR" Style="{StaticResource MetricLabel}" Margin="0,0,0,4" />
                        <UniformGrid Columns="2" Margin="0,0,0,4">
                            <Button Margin="0,0,2,2"
                                    Command="{Binding MapVm.ToggleDrawPolygonCommand}"
                                    ToolTip="Sol tık vertex · Sağ tık tamamla">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MapToolButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MapVm.IsDrawingPolygon}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource TacticalWarn}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource TacticalWarn}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialIcons:MaterialIcon Kind="VectorPolygon" Width="13" Height="13" VerticalAlignment="Center" />
                                    <TextBlock Text="ALAN ÇİZ" Margin="5,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,0,0,2" Style="{StaticResource MapToolButton}"
                                    Command="{Binding MapVm.ClearPolygonCmdCommand}"
                                    ToolTip="Çizilen alanı sil">
                                <StackPanel Orientation="Horizontal">
                                    <materialIcons:MaterialIcon Kind="VectorPolylineRemove" Width="13" Height="13" VerticalAlignment="Center" />
                                    <TextBlock Text="ALANI SİL" Margin="5,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="0,2,2,0" Style="{StaticResource MapToolButton}"
                                    Command="{Binding MapVm.ToggleTrailCommand}"
                                    ToolTip="İz çizgisini aç/kapat">
                                <StackPanel Orientation="Horizontal">
                                    <materialIcons:MaterialIcon Kind="VectorLine" Width="13" Height="13" VerticalAlignment="Center" />
                                    <TextBlock Text="İZ" Margin="5,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Margin="2,2,0,0" Style="{StaticResource MapToolButton}"
                                    Command="{Binding MapVm.ClearTrailCmdCommand}"
                                    ToolTip="İz çizgisini sil">
                                <StackPanel Orientation="Horizontal">
                                    <materialIcons:MaterialIcon Kind="Eraser" Width="13" Height="13" VerticalAlignment="Center" />
                                    <TextBlock Text="İZİ SİL" Margin="5,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- SAHTE HSS VERISI URETECI BUTONU -->
                            <Button Margin="0,2,2,0" Style="{StaticResource MapToolButton}"
                                    Command="{Binding MapVm.GenerateMockHssCmdCommand}"
                                    Visibility="{Binding IsSimulationMode, Converter={x:Static materialDesign:BooleanToVisibilityConverter.CollapsedInstance}}"
                                    ToolTip="HSS Bölgelerindeki kare/daire sorununu test etmek için sahte HSS ekler">
                                <StackPanel Orientation="Horizontal">
                                    <materialIcons:MaterialIcon Kind="Radar" Width="13" Height="13" VerticalAlignment="Center" Foreground="{StaticResource TacticalCritical}" />
                                    <TextBlock Text="SİM SENARYO" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TacticalCritical}" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <Separator Background="{StaticResource TacticalBorder}" Margin="0,8,0,8" />

                        <!-- ARKA PLAN + KATMANLAR — App.AppOptions.Map -->
                        <StackPanel DataContext="{x:Static ui:App.AppOptions}">
                            <TextBlock Text="ARKA PLAN" Style="{StaticResource MetricLabel}" Margin="0,0,0,4" />
                            <RadioButton GroupName="TileProvider" Margin="0,3"
                                         Content="Stadia Dark (taktik)"
                                         IsChecked="{Binding Map.TileProvider, Converter={StaticResource StringEqualsValueConverter}, ConverterParameter=StadiaAlidadeSmoothDark}" />
                            <RadioButton GroupName="TileProvider" Margin="0,3"
                                         Content="Google Map"
                                         IsChecked="{Binding Map.TileProvider, Converter={StaticResource StringEqualsValueConverter}, ConverterParameter=GoogleMap}" />
                            <RadioButton GroupName="TileProvider" Margin="0,3"
                                         Content="Google Uydu"
                                         IsChecked="{Binding Map.TileProvider, Converter={StaticResource StringEqualsValueConverter}, ConverterParameter=GoogleSatelliteMap}" />
                            <RadioButton GroupName="TileProvider" Margin="0,3"
                                         Content="Google Hibrit"
                                         IsChecked="{Binding Map.TileProvider, Converter={StaticResource StringEqualsValueConverter}, ConverterParameter=GoogleHybridMap}" />
                            <RadioButton GroupName="TileProvider" Margin="0,3"
                                         Content="OpenStreetMap"
                                         IsChecked="{Binding Map.TileProvider, Converter={StaticResource StringEqualsValueConverter}, ConverterParameter=OpenStreetMap}" />

                            <Separator Background="{StaticResource TacticalBorder}" Margin="0,8,0,8" />

                            <TextBlock Text="GÖRÜNÜR KATMANLAR" Style="{StaticResource MetricLabel}" Margin="0,0,0,4" />
                            <CheckBox IsChecked="{Binding Map.ShowGrid}"      Content="Grid katmanı"          Margin="0,3" />
                            <CheckBox IsChecked="{Binding Map.ShowBoundary}"  Content="Uçuş sahası sınırı"   Margin="0,3" />
                            <CheckBox IsChecked="{Binding Map.ShowHssZones}"  Content="HSS bölgeleri"         Margin="0,3" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <!-- ============ SAĞ KOLON: Accordion paneller ============ -->
        <sidebar:RightSidebar Grid.Column="1" />

        <!-- TOAST HOST — sağ üst köşede sidebar'ın üzerinde, TopBar'ın altında.
             AlertBus subscribe → 4 sn'lik popup uyarılar (Faz 8). -->
        <alerts:AlertToastHost Grid.Column="0" Grid.ColumnSpan="2"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,60,440,0"
                               Width="320" />


        <!-- ============ FULLSCREEN OVERLAY'LER (tüm window'u kaplar) ============ -->
        <core:OverlayHost Grid.Column="0" Grid.ColumnSpan="2"
                          IsOpen="{Binding IsCameraFullscreen, Mode=TwoWay}"
                          Title="GÖREV KAMERASI"
                          Subtitle="Tam ekran · ESC veya arka plana tıklayarak kapat"
                          HeaderIconKind="Video"
                          ContentMargin="0,60,0,0">
            <video:CameraFullscreenView />
        </core:OverlayHost>

        <core:OverlayHost Grid.Column="0" Grid.ColumnSpan="2"
                          IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
                          Title="AYARLAR"
                          Subtitle="GÖKDOĞAN YKİ yapılandırması"
                          HeaderIconKind="Cog"
                          ContentMargin="0,60,0,0">
            <views:SettingsView DataContext="{Binding Settings}" />
        </core:OverlayHost>

        <!-- KAMİKAZE TERMINAL PHASE — KamikazeFsm.IsActive olunca otomatik açılır.
             Mockup'taki APPROACH GEOMETRY (sol, dinamik SVG path) + OPTICAL TARGETING (sağ,
             kamera + QR detection) + büyük ABORT butonu. Tasarım: context-aware UI prensibi —
             pilot görev anında tek bir ekrana odaklanır. -->
        <core:OverlayHost Grid.Column="0" Grid.ColumnSpan="2"
                          IsOpen="{Binding IsKamikazeFullscreen, Mode=TwoWay}"
                          Title="KAMİKAZE GÖREVİ"
                          Subtitle="Terminal phase · ABORT butonu ile iptal et"
                          HeaderIconKind="Bomb"
                          ContentMargin="0,60,0,0">
            <kamikaze:KamikazeFullscreenView />
        </core:OverlayHost>
    </Grid>
</Window>
