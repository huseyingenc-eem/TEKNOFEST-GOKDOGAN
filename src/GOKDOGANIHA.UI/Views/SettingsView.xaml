<UserControl x:Class="GOKDOGANIHA.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
             mc:Ignorable="d"
             d:DesignWidth="1100" d:DesignHeight="700">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TacticalTextSecondary}" />
            <!-- MinWidth 160 → 120: label ile input arası gereksiz boşluk azaltıldı.
                 Ortak hizalanma için tüm row'lar aynı kolonu kullanır. -->
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="120" />
        </Style>

        <Style x:Key="FieldRow" TargetType="Grid">
            <!-- Üst margin 0 — section sağ içeriğin ilk row'u başlık ile aynı yatay
                 hizada başlar. Row'lar arası boşluk için sadece alt margin. -->
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{StaticResource TacticalOverlayBorder}" />
            <Setter Property="Margin" Value="0,28,0,28" />
        </Style>
    </UserControl.Resources>

    <TabControl Background="Transparent" BorderThickness="0" Padding="0">
        <!-- Lokal TabControl Template — tab strip outer ile aynı margin/maxwidth
             pattern'inde, içinde UniformGrid sol kolon (240) + gap (64) sonrası başlar.
             Sonuç: tab'lar sağ içerik kolonunun üstüne hizalı, sağ kenara kadar eşit dağılır. -->
        <TabControl.Resources>
            <Style TargetType="TabControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <!-- Tab strip container — outer StackPanel ile aynı bounding -->
                                <Border Grid.Row="0"
                                        HorizontalAlignment="Stretch"
                                        MaxWidth="1100"
                                        Margin="16,0,32,0"
                                        Background="Transparent">
                                    <UniformGrid Rows="1"
                                                 IsItemsHost="True"
                                                 Margin="304,0,0,0"
                                                 Background="Transparent"
                                                 KeyboardNavigation.TabIndex="1" />
                                </Border>
                                <Border Grid.Row="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="SelectedContent" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>

        <!-- ============== BAĞLANTI ============== -->
        <core:IconTabItem IconKind="Server" Label="BAĞLANTI">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                    <core:SettingsSection IconKind="Server"
                                          Title="YARIŞMA SUNUCUSU"
                                          Subtitle="Adres + kimlik bilgileri">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Sunucu adresi" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Server.ServerBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="http://127.0.0.25:5000" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Kullanıcı adı" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Server.TeamUsername, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Şifre" Style="{StaticResource FieldLabel}" />
                                <PasswordBox Grid.Column="1" x:Name="PasswordInput"
                                             PasswordChanged="OnPasswordChanged" />
                            </Grid>
                    <CheckBox IsChecked="{Binding Server.UseTestEnvironment}"
                              Content="Test / mock sunucu profili"
                              Margin="160,10,0,0" />
                    <TextBlock Text="Kapalı: resmi yarışma profili; simülasyon telemetrisi gönderilmez. Açık: yerel mock sunucu ve laboratuvar senaryolarına izin verilir."
                               FontSize="10" FontStyle="Italic"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TacticalWarn}"
                               Margin="184,4,0,0" />

                            <StackPanel Orientation="Horizontal" Margin="160,16,0,0">
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="BAĞLANTIYI TEST ET"
                                        Command="{Binding Server.TestConnectionCommand}"
                                        Padding="18,8" FontSize="11"
                                        Margin="0,0,10,0" />
                                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                        Content="BAĞLAN · POLL BAŞLAT"
                                        Command="{Binding Server.ConnectCommand}"
                                        Padding="18,8" FontSize="11"
                                        Margin="0,0,10,0" />
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="BAĞLANTIYI KES"
                                        Command="{Binding Server.DisconnectCommand}"
                                        Padding="18,8" FontSize="11" />
                            </StackPanel>
                            <TextBlock Margin="160,12,0,0" FontFamily="Consolas" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="SUNUCU OTURUMU: BAĞLI DEĞİL" />
                                        <Setter Property="Foreground" Value="{StaticResource TacticalCritical}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Server.IsConnected}" Value="True">
                                                <Setter Property="Text" Value="SUNUCU OTURUMU: BAĞLI" />
                                                <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="AccountGroup"
                                          Title="TAKIM"
                                          Subtitle="Telemetri paketlerinde gönderilen kimlik">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Takım numarası" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Team.TeamNumber, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Hakemler tarafından verilir" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Çağrı işareti" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Team.CallSign, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="GÖKDOĞAN-1" />
                            </Grid>
                            <!-- KTR ekran görüntüsünde gizli — şartname notu yorum satırına alındı.
                            <TextBlock Text="Takım numarası her /api/telemetri_gonder paketinde zorunlu."
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="160,12,0,0" />
                            -->
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="AccessPoint"
                                          Title="TELEMETRİ"
                                          Subtitle="İHA durum paketlerinin gönderimi">
                        <StackPanel>
                            <core:SliderSettingRow Label="Gönderim frekansı"
                                                   Value="{Binding Telemetry.Hz}"
                                                   Minimum="1" Maximum="2" TickFrequency="0.5"
                                                   ValueFormat="0.0" Suffix=" Hz" />

                    <CheckBox IsChecked="{Binding Telemetry.AutoReconnect}"
                              Content="Yarışma sunucusu oturumu kopunca yeniden bağlan"
                              Margin="160,10,0,0" />

                    <Border Style="{StaticResource PanelCard}" Margin="0,18,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AKTİF UÇUŞ VERİ KAYNAĞI"
                                           Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding Telemetry.FlightBackendStatusText}"
                                           Margin="0,5,12,0"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TacticalTextPrimary}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding Telemetry.ToggleSimulationCommand}"
                                    Padding="16,8"
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Content" Value="SİMÜLASYONA GEÇ" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Telemetry.IsSimulationActive}" Value="True">
                                                <Setter Property="Content" Value="CANLIYA GEÇ" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <TextBlock Text="MAVLINK CANLI BAĞLANTI"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TacticalAccent}"
                               Margin="0,12,0,4" />

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bağlantı türü" Style="{StaticResource FieldLabel}" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Telemetry.MavlinkTransportOptions}"
                                  SelectedItem="{Binding Telemetry.MavlinkTransport}" />
                    </Grid>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Telemetry.IsUdpMavlinkTransport}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Dinleme adresi" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Telemetry.MavlinkListenAddress, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="0.0.0.0" />
                        </Grid>
                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="UDP port" Style="{StaticResource FieldLabel}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Telemetry.MavlinkPort, UpdateSourceTrigger=LostFocus}" />
                        </Grid>
                        <TextBlock Text="SITL, MAVProxy veya UDP köprüsü kullanıyorsanız bu türü seçin."
                                   Margin="160,-4,0,12" FontSize="10" FontStyle="Italic"
                                   Foreground="{StaticResource TacticalTextSecondary}" />
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Telemetry.IsSerialMavlinkTransport}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="COM portu" Style="{StaticResource FieldLabel}" />
                            <ComboBox Grid.Column="1" IsEditable="True"
                                      ItemsSource="{Binding Telemetry.AvailableSerialPorts}"
                                      Text="{Binding Telemetry.MavlinkSerialPortName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2" Content="YENİLE"
                                    Command="{Binding Telemetry.RefreshSerialPortsCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Padding="12,6" Margin="8,0,0,0" />
                        </Grid>
                        <Grid Style="{StaticResource FieldRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Baud hızı" Style="{StaticResource FieldLabel}" />
                            <ComboBox Grid.Column="1" IsEditable="True"
                                      ItemsSource="{Binding Telemetry.MavlinkBaudRateOptions}"
                                      Text="{Binding Telemetry.MavlinkBaudRate, UpdateSourceTrigger=LostFocus}" />
                        </Grid>
                        <TextBlock Text="RFD868x yer modemi USB ile bu bilgisayara bağlıysa Seri türünü kullanın. Hat 8N1 olarak açılır."
                                   Margin="160,-4,0,12" FontSize="10" FontStyle="Italic"
                                   Foreground="{StaticResource TacticalTextSecondary}" />
                        <TextBlock Text="{Binding Telemetry.SerialPortStatusText}"
                                   Margin="160,-4,0,12" FontSize="11" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TacticalWarn}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Telemetry.IsSelectedSerialPortAvailable}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TacticalOk}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Beklenen system ID" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Telemetry.MavlinkExpectedSystemId, UpdateSourceTrigger=LostFocus}"
                                 materialDesign:HintAssist.Hint="0 = otomatik" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Veri bayatlama süresi" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Telemetry.MavlinkStaleAfterSeconds, UpdateSourceTrigger=LostFocus}"
                                 materialDesign:HintAssist.Hint="saniye" />
                    </Grid>

                    <CheckBox IsChecked="{Binding Telemetry.MavlinkAutoReconnect}"
                              Content="USB/seri hat kopunca portu otomatik izle ve yeniden bağlan"
                              Margin="160,0,0,12" />

                    <TextBlock Text="{Binding Telemetry.MavlinkConnectionSummary}"
                               Margin="160,0,0,4" FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TacticalTextPrimary}" />

                    <Button Content="MAVLINK'İ YENİ AYARLARLA BAĞLA"
                            Command="{Binding Telemetry.ReconnectLiveCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Left"
                            Margin="160,8,0,0"
                            Padding="16,8" />

                    <TextBlock Text="Şartname: 2 Hz üzeri telemetri 400 döner."
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TacticalWarn}"
                               Margin="160,16,0,0" />
                        </StackPanel>
                    </core:SettingsSection>

                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== VİDEO ============== -->
        <core:IconTabItem IconKind="Video" Label="VİDEO">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">
                    <core:SettingsSection IconKind="Video"
                                          Title="VİDEO AKIŞI"
                                          Subtitle="Kamera bağlantısı ve kayıt profili">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="RTSP URL" Style="{StaticResource FieldLabel}" />
                                <!-- LostFocus: URL yazarken her tuşta video motorunu yeniden başlatıp
                                     UI'ı dondurmasın; alandan çıkınca tek seferde bağlanır. -->
                                <TextBox Grid.Column="1"
                                         Text="{Binding Video.RtspUrl, UpdateSourceTrigger=LostFocus}" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Profil" Style="{StaticResource FieldLabel}" />
                                <ComboBox Grid.Column="1"
                                          SelectedValue="{Binding Video.Preset}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="720p/30" />
                                    <ComboBoxItem Content="1080p/30" />
                                    <ComboBoxItem Content="1080p/60" />
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Aktarım" Style="{StaticResource FieldLabel}" />
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding Video.UseTcp}"
                                          Content="TCP kullan  (işaretsiz = UDP · KTR 6.2 varsayılanı, düşük gecikme)" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ağ tamponu" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Video.NetworkCachingMs, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="ms · düşük = az gecikme (0–5000)" />
                            </Grid>
                        </StackPanel>
                    </core:SettingsSection>
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== GÜVENLİK ============== -->
        <core:IconTabItem IconKind="ShieldAlert" Label="GÜVENLİK">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                    <core:SettingsSection IconKind="BellRing"
                                          Title="UYARILAR"
                                          Subtitle="Sesli bildirimler ve eşikler">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding Alerts.EnableAudioAlerts}" Content="Sesli uyarılar" Margin="0,8,0,0" />
                            <CheckBox IsChecked="{Binding Alerts.EnableLockBeep}" Content="Kilitlenme bip sesi" Margin="0,8,0,0" />

                            <core:SliderSettingRow Label="Düşük batarya eşiği"
                                                   Value="{Binding Alerts.LowBatteryThreshold}"
                                                   Minimum="18" Maximum="30" TickFrequency="1"
                                                   Suffix=" V" Foreground="{StaticResource TacticalWarn}"
                                                   Margin="0,16,0,8" />

                            <TextBlock Text="YAKLAŞMA EŞİKLERİ" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="0,20,0,8" />

                            <core:SliderSettingRow Label="Rakip İHA yakınlığı"
                                                   Value="{Binding Alerts.OpponentProximityThreshold}"
                                                   Minimum="100" Maximum="2000" TickFrequency="100"
                                                   Suffix=" m" />
                            <core:SliderSettingRow Label="HSS tampon mesafesi"
                                                   Value="{Binding Alerts.HssProximityThreshold}"
                                                   Minimum="20" Maximum="300" TickFrequency="10"
                                                   Suffix=" m" Foreground="{StaticResource TacticalCritical}" />
                            <core:SliderSettingRow Label="Saha sınırı yakınlığı"
                                                   Value="{Binding Alerts.BoundaryProximityThreshold}"
                                                   Minimum="50" Maximum="500" TickFrequency="25"
                                                   Suffix=" m" Foreground="{StaticResource TacticalWarn}" />
                            <core:SliderSettingRow Label="Haberleşme gecikme"
                                                   Value="{Binding Alerts.CommLatencyThreshold}"
                                                   Minimum="100" Maximum="2000" TickFrequency="100"
                                                   Suffix=" ms" Foreground="{StaticResource TacticalWarn}" />
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="MapMarkerRadius"
                                          Title="GEOFENCE"
                                          Subtitle="Uçuş sahası sınırları ve RTL parametreleri"
                                          DataContext="{Binding Geofence}">
                        <StackPanel>
                            <core:SliderSettingRow Label="Max irtifa"
                                                   Value="{Binding MaxAltitudeMeters}"
                                                   Minimum="50" Maximum="500" TickFrequency="25" Suffix=" m" />
                            <core:SliderSettingRow Label="Max mesafe (home)"
                                                   Value="{Binding MaxDistanceMeters}"
                                                   Minimum="500" Maximum="5000" TickFrequency="250" Suffix=" m" />
                            <core:SliderSettingRow Label="RTL irtifa"
                                                   Value="{Binding RtlAltitudeMeters}"
                                                   Minimum="50" Maximum="300" TickFrequency="10"
                                                   Suffix=" m" Foreground="{StaticResource TacticalOk}" />
                            <core:SliderSettingRow Label="Tampon bölge"
                                                   Value="{Binding BufferMeters}"
                                                   Minimum="25" Maximum="500" TickFrequency="25"
                                                   Suffix=" m" Foreground="{StaticResource TacticalWarn}" />
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="ShieldAlert"
                                          Title="FAILSAFE"
                                          Subtitle="GCS timeout ve batarya failsafe davranışları"
                                          DataContext="{Binding Failsafe}">
                        <StackPanel>
                            <core:SliderSettingRow Label="GCS timeout"
                                                   Value="{Binding GcsTimeoutSeconds}"
                                                   Minimum="5" Maximum="30" TickFrequency="1"
                                                   Suffix=" sn" Foreground="{StaticResource TacticalCritical}" />
                            <core:SliderSettingRow Label="Batarya RTL eşiği"
                                                   Value="{Binding BatteryRtlPercent}"
                                                   Minimum="10" Maximum="50" TickFrequency="1"
                                                   Prefix="%" Foreground="{StaticResource TacticalWarn}" />
                            <TextBlock Text="Şartname: GCS kaybı 10 sn → otonom iniş (default)"
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="160,16,0,0" />
                        </StackPanel>
                    </core:SettingsSection>

                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== OTONOM ============== -->
        <core:IconTabItem IconKind="Robot" Label="OTONOM" DataContext="{Binding Autonomy}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                    <core:SettingsSection IconKind="Target"
                                          Title="HEDEF AĞIRLIKLARI"
                                          Subtitle="Mesafe · açı · geçmiş · risk skoru">
                        <StackPanel>
                            <core:SliderSettingRow Label="Mesafe (w₁)"
                                                   Value="{Binding WeightDistance}"
                                                   Minimum="0" Maximum="1" TickFrequency="0.05" ValueFormat="0.00" />
                            <core:SliderSettingRow Label="Açı uyumu (w₂)"
                                                   Value="{Binding WeightAngle}"
                                                   Minimum="0" Maximum="1" TickFrequency="0.05" ValueFormat="0.00" />
                            <core:SliderSettingRow Label="Hedef geçmişi (w₃)"
                                                   Value="{Binding WeightHistory}"
                                                   Minimum="0" Maximum="1" TickFrequency="0.05" ValueFormat="0.00" />
                            <core:SliderSettingRow Label="HSS riski (w₄)"
                                                   Value="{Binding WeightRisk}"
                                                   Minimum="0" Maximum="1" TickFrequency="0.05" ValueFormat="0.00"
                                                   Foreground="{StaticResource TacticalCritical}" />
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="Crosshairs"
                                          Title="KİLİTLENME"
                                          Subtitle="Şartname m. 6.1.1 — tolerans, pencere, gerekli süre">
                        <StackPanel>
                            <core:SliderSettingRow Label="Boyut toleransı"
                                                   Value="{Binding LockTolerancePercent}"
                                                   Minimum="3" Maximum="10" TickFrequency="1" Prefix="%" />
                            <core:SliderSettingRow Label="Pencere süresi"
                                                   Value="{Binding LockWindowSeconds}"
                                                   Minimum="3" Maximum="10" TickFrequency="0.5"
                                                   ValueFormat="0.0" Suffix=" sn" />
                            <core:SliderSettingRow Label="Gerekli süre"
                                                   Value="{Binding LockRequiredSeconds}"
                                                   Minimum="2" Maximum="8" TickFrequency="0.5"
                                                   ValueFormat="0.0" Suffix=" sn" />
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="Bomb"
                                          Title="KAMİKAZE"
                                          Subtitle="TYF: 100m → 45° dalış → 30m pas geç">
                        <StackPanel>
                            <core:SliderSettingRow Label="Başlangıç irtifası"
                                                   Value="{Binding KamikazeApproachAltitude}"
                                                   Minimum="50" Maximum="200" TickFrequency="10" Suffix=" m" />
                            <core:SliderSettingRow Label="Dalış açısı"
                                                   Value="{Binding KamikazeDiveAngle}"
                                                   Minimum="20" Maximum="70" TickFrequency="5"
                                                   Suffix="°" Foreground="{StaticResource TacticalWarn}" />
                            <core:SliderSettingRow Label="Pas geç irtifası"
                                                   Value="{Binding KamikazePullUpAltitude}"
                                                   Minimum="20" Maximum="80" TickFrequency="5"
                                                   Suffix=" m" Foreground="{StaticResource TacticalOk}" />
                        </StackPanel>
                    </core:SettingsSection>

                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>
    </TabControl>
</UserControl>
