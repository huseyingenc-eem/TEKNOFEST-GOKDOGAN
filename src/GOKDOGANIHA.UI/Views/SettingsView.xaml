<UserControl x:Class="GOKDOGANIHA.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="600">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TacticalTextSecondary}" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="160" />
        </Style>

        <Style x:Key="FieldRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,8,0,8" />
        </Style>

        <Style x:Key="TabHeading" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <DataTemplate x:Key="TabHeadingTemplate">
            <!-- Used as a mini-template for the big heading inside each tab body. -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,18" />
        </DataTemplate>
    </UserControl.Resources>

    <TabControl Background="Transparent" BorderThickness="0" Padding="0">

        <!-- ============== SUNUCU ============== -->
        <core:IconTabItem IconKind="Server" Label="SUNUCU">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="680" Margin="32,24,32,24">
                    <StackPanel Style="{StaticResource TabHeading}">
                        <materialIcons:MaterialIcon Kind="Server" Width="18" Height="18"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="YARIŞMA SUNUCUSU" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="Takım kimlik bilgileri ve sunucu adresi"
                                   FontSize="11"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Sunucu adresi" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Server.ServerBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="http://127.0.0.25:5000" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Kullanıcı adı" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Server.TeamUsername, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Şifre" Style="{StaticResource FieldLabel}" />
                        <PasswordBox Grid.Column="1" x:Name="PasswordInput"
                                     PasswordChanged="OnPasswordChanged" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="160,16,0,0">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="BAĞLANTIYI TEST ET"
                                Command="{Binding Server.TestConnectionCommand}"
                                Padding="18,8" FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== TAKIM ============== -->
        <core:IconTabItem IconKind="AccountGroup" Label="TAKIM">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="680" Margin="32,24,32,24">
                    <StackPanel Style="{StaticResource TabHeading}">
                        <materialIcons:MaterialIcon Kind="AccountGroup" Width="18" Height="18"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="TAKIM" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="Telemetri paketlerinde gönderilen kimlik"
                                   FontSize="11"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Takım numarası" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Team.TeamNumber, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Hakemler tarafından verilir" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Çağrı işareti" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Team.CallSign, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="GÖKDOĞAN-1" />
                    </Grid>

                    <TextBlock Text="Takım numarası her /api/telemetri_gonder paketinde zorunlu."
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TacticalTextSecondary}"
                               Margin="160,12,0,0" />
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== TELEMETRİ ============== -->
        <core:IconTabItem IconKind="AccessPoint" Label="TELEMETRİ">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="680" Margin="32,24,32,24">
                    <StackPanel Style="{StaticResource TabHeading}">
                        <materialIcons:MaterialIcon Kind="AccessPoint" Width="18" Height="18"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="TELEMETRİ" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="İHA durum paketlerinin gönderimi"
                                   FontSize="11"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Gönderim frekansı" Style="{StaticResource FieldLabel}" />
                        <Slider Grid.Column="1" Minimum="0.5" Maximum="2.0" TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Telemetry.Hz}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                   Foreground="{StaticResource TacticalAccent}"
                                   VerticalAlignment="Center" TextAlignment="Right">
                            <TextBlock.Text>
                                <Binding Path="Telemetry.Hz" StringFormat="{}{0:0.0} Hz" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <CheckBox IsChecked="{Binding Telemetry.AutoReconnect}"
                              Content="Bağlantı kopunca otomatik yeniden bağlan"
                              Margin="160,10,0,0" />

                    <TextBlock Text="Şartname: 2 Hz üzeri telemetri 400 döner."
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TacticalWarn}"
                               Margin="160,16,0,0" />
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== VİDEO ============== -->
        <core:IconTabItem IconKind="Video" Label="VİDEO">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="680" Margin="32,24,32,24">
                    <StackPanel Style="{StaticResource TabHeading}">
                        <materialIcons:MaterialIcon Kind="Video" Width="18" Height="18"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="VİDEO AKIŞI" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="Kamera bağlantısı ve kayıt profili"
                                   FontSize="11"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="RTSP URL" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Video.RtspUrl, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Profil" Style="{StaticResource FieldLabel}" />
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding Video.Preset}" SelectedValuePath="Content">
                            <ComboBoxItem Content="720p/30" />
                            <ComboBoxItem Content="1080p/30" />
                            <ComboBoxItem Content="1080p/60" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== HARİTA ============== -->
        <core:IconTabItem IconKind="Map" Label="HARİTA">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="680" Margin="32,24,32,24">
                    <StackPanel Style="{StaticResource TabHeading}">
                        <materialIcons:MaterialIcon Kind="Map" Width="18" Height="18"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="HARİTA" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="Tile sağlayıcı ve görünür katmanlar"
                                   FontSize="11"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tile sağlayıcı" Style="{StaticResource FieldLabel}" />
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding Map.TileProvider}" SelectedValuePath="Content">
                            <ComboBoxItem Content="OpenStreetMap" />
                            <ComboBoxItem Content="Esri World Imagery" />
                            <ComboBoxItem Content="Google Satellite" />
                        </ComboBox>
                    </Grid>

                    <CheckBox IsChecked="{Binding Map.ShowGrid}" Content="Grid katmanı" Margin="160,10,0,0" />
                    <CheckBox IsChecked="{Binding Map.ShowBoundary}" Content="Uçuş sahası sınırı" Margin="160,8,0,0" />
                    <CheckBox IsChecked="{Binding Map.ShowHssZones}" Content="HSS bölgeleri" Margin="160,8,0,0" />
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== UYARILAR ============== -->
        <core:IconTabItem IconKind="BellRing" Label="UYARILAR">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="680" Margin="32,24,32,24">
                    <StackPanel Style="{StaticResource TabHeading}">
                        <materialIcons:MaterialIcon Kind="BellRing" Width="18" Height="18"
                                                    Foreground="{StaticResource TacticalAccent}"
                                                    VerticalAlignment="Center" />
                        <TextBlock Text="UYARILAR" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TacticalTextPrimary}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="Sesli bildirimler ve eşikler"
                                   FontSize="11"
                                   Foreground="{StaticResource TacticalTextSecondary}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <CheckBox IsChecked="{Binding Alerts.EnableAudioAlerts}" Content="Sesli uyarılar" Margin="0,8,0,0" />
                    <CheckBox IsChecked="{Binding Alerts.EnableLockBeep}" Content="Kilitlenme bip sesi" Margin="0,8,0,0" />

                    <Grid Style="{StaticResource FieldRow}" Margin="0,16,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Düşük batarya eşiği" Style="{StaticResource FieldLabel}" />
                        <Slider Grid.Column="1" Minimum="18" Maximum="30" TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Alerts.LowBatteryThreshold}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                   Foreground="{StaticResource TacticalWarn}"
                                   VerticalAlignment="Center" TextAlignment="Right">
                            <TextBlock.Text>
                                <Binding Path="Alerts.LowBatteryThreshold" StringFormat="{}{0} V" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <!-- Yakınlık eşikleri — tüketici AlertService sonraki iterasyonda eklenecek. -->
                    <TextBlock Text="YAKLAŞMA EŞİKLERİ" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TacticalTextSecondary}"
                               Margin="0,20,0,8" />

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Rakip İHA yakınlığı" Style="{StaticResource FieldLabel}" />
                        <Slider Grid.Column="1" Minimum="100" Maximum="2000" TickFrequency="100"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Alerts.OpponentProximityThreshold}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                   Foreground="{StaticResource TacticalAccent}"
                                   VerticalAlignment="Center" TextAlignment="Right">
                            <TextBlock.Text>
                                <Binding Path="Alerts.OpponentProximityThreshold" StringFormat="{}{0:0} m" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="HSS tampon mesafesi" Style="{StaticResource FieldLabel}" />
                        <Slider Grid.Column="1" Minimum="20" Maximum="300" TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Alerts.HssProximityThreshold}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                   Foreground="{StaticResource TacticalCritical}"
                                   VerticalAlignment="Center" TextAlignment="Right">
                            <TextBlock.Text>
                                <Binding Path="Alerts.HssProximityThreshold" StringFormat="{}{0:0} m" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Saha sınırı yakınlığı" Style="{StaticResource FieldLabel}" />
                        <Slider Grid.Column="1" Minimum="50" Maximum="500" TickFrequency="25"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Alerts.BoundaryProximityThreshold}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                   Foreground="{StaticResource TacticalWarn}"
                                   VerticalAlignment="Center" TextAlignment="Right">
                            <TextBlock.Text>
                                <Binding Path="Alerts.BoundaryProximityThreshold" StringFormat="{}{0:0} m" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Haberleşme gecikme" Style="{StaticResource FieldLabel}" />
                        <Slider Grid.Column="1" Minimum="100" Maximum="2000" TickFrequency="100"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Alerts.CommLatencyThreshold}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                   Foreground="{StaticResource TacticalWarn}"
                                   VerticalAlignment="Center" TextAlignment="Right">
                            <TextBlock.Text>
                                <Binding Path="Alerts.CommLatencyThreshold" StringFormat="{}{0} ms" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>
    </TabControl>
</UserControl>
