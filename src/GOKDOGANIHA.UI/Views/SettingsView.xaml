<UserControl x:Class="GOKDOGANIHA.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:core="clr-namespace:GOKDOGANIHA.UI.Core"
             mc:Ignorable="d"
             d:DesignWidth="1100" d:DesignHeight="700">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TacticalTextSecondary}" />
            <!-- MinWidth 160 → 120: label ile input arası gereksiz boşluk azaltıldı.
                 Ortak hizalanma için tüm row'lar aynı kolonu kullanır. -->
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="120" />
        </Style>

        <Style x:Key="FieldRow" TargetType="Grid">
            <!-- Üst margin 0 — section sağ içeriğin ilk row'u başlık ile aynı yatay
                 hizada başlar. Row'lar arası boşluk için sadece alt margin. -->
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{StaticResource TacticalOverlayBorder}" />
            <Setter Property="Margin" Value="0,28,0,28" />
        </Style>
    </UserControl.Resources>

    <TabControl Background="Transparent" BorderThickness="0" Padding="0">
        <!-- Lokal TabControl Template — tab strip outer ile aynı margin/maxwidth
             pattern'inde, içinde UniformGrid sol kolon (240) + gap (64) sonrası başlar.
             Sonuç: tab'lar sağ içerik kolonunun üstüne hizalı, sağ kenara kadar eşit dağılır. -->
        <TabControl.Resources>
            <Style TargetType="TabControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <!-- Tab strip container — outer StackPanel ile aynı bounding -->
                                <Border Grid.Row="0"
                                        HorizontalAlignment="Stretch"
                                        MaxWidth="1100"
                                        Margin="16,0,32,0"
                                        Background="Transparent">
                                    <UniformGrid Rows="1"
                                                 IsItemsHost="True"
                                                 Margin="304,0,0,0"
                                                 Background="Transparent"
                                                 KeyboardNavigation.TabIndex="1" />
                                </Border>
                                <Border Grid.Row="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="SelectedContent" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>

        <!-- ============== BAĞLANTI ============== -->
        <core:IconTabItem IconKind="Server" Label="BAĞLANTI">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                    <core:SettingsSection IconKind="Server"
                                          Title="YARIŞMA SUNUCUSU"
                                          Subtitle="Adres + kimlik bilgileri">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Sunucu adresi" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Server.ServerBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="http://127.0.0.25:5000" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Kullanıcı adı" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Server.TeamUsername, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Şifre" Style="{StaticResource FieldLabel}" />
                                <PasswordBox Grid.Column="1" x:Name="PasswordInput"
                                             PasswordChanged="OnPasswordChanged" />
                            </Grid>
                    <CheckBox IsChecked="{Binding Server.UseTestEnvironment}"
                              Content="Test / mock sunucu profili"
                              Margin="160,10,0,0" />
                    <TextBlock Text="Kapalı: resmi yarışma profili; simülasyon telemetrisi gönderilmez. Açık: yerel mock sunucu ve laboratuvar senaryolarına izin verilir."
                               FontSize="10" FontStyle="Italic"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TacticalWarn}"
                               Margin="184,4,0,0" />

                            <StackPanel Orientation="Horizontal" Margin="160,16,0,0">
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="BAĞLANTIYI TEST ET"
                                        Command="{Binding Server.TestConnectionCommand}"
                                        Padding="18,8" FontSize="11"
                                        Margin="0,0,10,0" />
                                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                        Content="BAĞLAN · POLL BAŞLAT"
                                        Command="{Binding Server.ConnectCommand}"
                                        Padding="18,8" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="AccountGroup"
                                          Title="TAKIM"
                                          Subtitle="Telemetri paketlerinde gönderilen kimlik">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Takım numarası" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Team.TeamNumber, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Hakemler tarafından verilir" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Çağrı işareti" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Team.CallSign, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="GÖKDOĞAN-1" />
                            </Grid>
                            <!-- KTR ekran görüntüsünde gizli — şartname notu yorum satırına alındı.
                            <TextBlock Text="Takım numarası her /api/telemetri_gonder paketinde zorunlu."
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="160,12,0,0" />
                            -->
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="AccessPoint"
                                          Title="TELEMETRİ"
                                          Subtitle="İHA durum paketlerinin gönderimi">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Gönderim frekansı" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="1.0" Maximum="2.0" TickFrequency="0.5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Telemetry.Hz}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text>
                                        <Binding Path="Telemetry.Hz" StringFormat="{}{0:0.0} Hz" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>

                    <CheckBox IsChecked="{Binding Telemetry.AutoReconnect}"
                              Content="Bağlantı kopunca otomatik yeniden bağlan"
                              Margin="160,10,0,0" />

                    <Border Style="{StaticResource PanelCard}" Margin="0,18,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AKTİF UÇUŞ VERİ KAYNAĞI"
                                           Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding Telemetry.FlightBackendStatusText}"
                                           Margin="0,5,12,0"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TacticalTextPrimary}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding Telemetry.ToggleSimulationCommand}"
                                    Padding="16,8"
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Content" Value="SİMÜLASYONA GEÇ" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Telemetry.IsSimulationActive}" Value="True">
                                                <Setter Property="Content" Value="CANLIYA GEÇ" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <TextBlock Text="MAVLINK UDP"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TacticalAccent}"
                               Margin="0,12,0,4" />

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dinleme adresi" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Telemetry.MavlinkListenAddress, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="0.0.0.0" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="UDP port" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Telemetry.MavlinkPort, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Beklenen system ID" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Telemetry.MavlinkExpectedSystemId, UpdateSourceTrigger=LostFocus}"
                                 materialDesign:HintAssist.Hint="0 = otomatik" />
                    </Grid>

                    <Grid Style="{StaticResource FieldRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Veri bayatlama süresi" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Telemetry.MavlinkStaleAfterSeconds, UpdateSourceTrigger=LostFocus}"
                                 materialDesign:HintAssist.Hint="saniye" />
                    </Grid>

                    <Button Content="MAVLINK'İ YENİ AYARLARLA BAĞLA"
                            Command="{Binding Telemetry.ReconnectLiveCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Left"
                            Margin="160,8,0,0"
                            Padding="16,8" />

                    <TextBlock Text="Şartname: 2 Hz üzeri telemetri 400 döner."
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TacticalWarn}"
                               Margin="160,16,0,0" />
                            <CheckBox IsChecked="{Binding Telemetry.AutoReconnect}"
                                      Content="Bağlantı kopunca otomatik yeniden bağlan"
                                      Margin="160,10,0,0" />
                            <CheckBox IsChecked="{Binding Telemetry.UseSimulator}"
                                      Content="Simülatör ile sahte İHA verisi üret (gerçek MAVLink yokken)"
                                      Margin="160,10,0,0" />
                            <!-- KTR ekran görüntüsünde gizli — açıklayıcı notlar yorum satırına alındı.
                            <TextBlock Text="Açıkken: 100ms tick'te FlightState sahte değerlerle dolar (sin/cos osilasyonlar). Yarışma modunda KAPALI tutun — gerçek pixhawk yokken telemetri sıfır kalır."
                                       FontSize="10" FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="184,4,0,0" />
                            <TextBlock Text="Şartname: 2 Hz üzeri telemetri 400 döner."
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{StaticResource TacticalWarn}"
                                       Margin="160,16,0,0" />
                            -->
                        </StackPanel>
                    </core:SettingsSection>

                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== VİDEO ============== -->
        <core:IconTabItem IconKind="Video" Label="VİDEO">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">
                    <core:SettingsSection IconKind="Video"
                                          Title="VİDEO AKIŞI"
                                          Subtitle="Kamera bağlantısı ve kayıt profili">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="RTSP URL" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Video.RtspUrl, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Profil" Style="{StaticResource FieldLabel}" />
                                <ComboBox Grid.Column="1"
                                          SelectedValue="{Binding Video.Preset}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="720p/30" />
                                    <ComboBoxItem Content="1080p/30" />
                                    <ComboBoxItem Content="1080p/60" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </core:SettingsSection>
                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== GÜVENLİK ============== -->
        <core:IconTabItem IconKind="ShieldAlert" Label="GÜVENLİK">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                    <core:SettingsSection IconKind="BellRing"
                                          Title="UYARILAR"
                                          Subtitle="Sesli bildirimler ve eşikler">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding Alerts.EnableAudioAlerts}" Content="Sesli uyarılar" Margin="0,8,0,0" />
                            <CheckBox IsChecked="{Binding Alerts.EnableLockBeep}" Content="Kilitlenme bip sesi" Margin="0,8,0,0" />

                            <Grid Style="{StaticResource FieldRow}" Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Düşük batarya eşiği" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="18" Maximum="30" TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Alerts.LowBatteryThreshold}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalWarn}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text>
                                        <Binding Path="Alerts.LowBatteryThreshold" StringFormat="{}{0} V" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>

                            <TextBlock Text="YAKLAŞMA EŞİKLERİ" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="0,20,0,8" />

                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rakip İHA yakınlığı" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="100" Maximum="2000" TickFrequency="100"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Alerts.OpponentProximityThreshold}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="Alerts.OpponentProximityThreshold" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="HSS tampon mesafesi" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="20" Maximum="300" TickFrequency="10"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Alerts.HssProximityThreshold}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalCritical}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="Alerts.HssProximityThreshold" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Saha sınırı yakınlığı" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="50" Maximum="500" TickFrequency="25"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Alerts.BoundaryProximityThreshold}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalWarn}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="Alerts.BoundaryProximityThreshold" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Haberleşme gecikme" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="100" Maximum="2000" TickFrequency="100"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Alerts.CommLatencyThreshold}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalWarn}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="Alerts.CommLatencyThreshold" StringFormat="{}{0} ms" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="MapMarkerRadius"
                                          Title="GEOFENCE"
                                          Subtitle="Uçuş sahası sınırları ve RTL parametreleri"
                                          DataContext="{Binding Geofence}">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max irtifa" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="50" Maximum="500" TickFrequency="25"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding MaxAltitudeMeters}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="MaxAltitudeMeters" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max mesafe (home)" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="500" Maximum="5000" TickFrequency="250"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding MaxDistanceMeters}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="MaxDistanceMeters" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="RTL irtifa" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="50" Maximum="300" TickFrequency="10"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding RtlAltitudeMeters}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalOk}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="RtlAltitudeMeters" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Tampon bölge" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="25" Maximum="500" TickFrequency="25"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding BufferMeters}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalWarn}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="BufferMeters" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="ShieldAlert"
                                          Title="FAILSAFE"
                                          Subtitle="GCS timeout ve batarya failsafe davranışları"
                                          DataContext="{Binding Failsafe}">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="GCS timeout" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="5" Maximum="30" TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding GcsTimeoutSeconds}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalCritical}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="GcsTimeoutSeconds" StringFormat="{}{0} sn" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Batarya RTL eşiği" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="10" Maximum="50" TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding BatteryRtlPercent}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalWarn}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="BatteryRtlPercent" StringFormat="{}%{0}" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <TextBlock Text="Şartname: GCS kaybı 10 sn → otonom iniş (default)"
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{StaticResource TacticalTextSecondary}"
                                       Margin="160,16,0,0" />
                        </StackPanel>
                    </core:SettingsSection>

                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>

        <!-- ============== OTONOM ============== -->
        <core:IconTabItem IconKind="Robot" Label="OTONOM" DataContext="{Binding Autonomy}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                    <core:SettingsSection IconKind="Target"
                                          Title="HEDEF AĞIRLIKLARI"
                                          Subtitle="Mesafe · açı · geçmiş · risk skoru">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mesafe (w₁)" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding WeightDistance}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="WeightDistance" StringFormat="{}{0:0.00}" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Açı uyumu (w₂)" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding WeightAngle}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="WeightAngle" StringFormat="{}{0:0.00}" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Hedef geçmişi (w₃)" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding WeightHistory}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="WeightHistory" StringFormat="{}{0:0.00}" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="HSS riski (w₄)" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding WeightRisk}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalCritical}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="WeightRisk" StringFormat="{}{0:0.00}" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="Crosshairs"
                                          Title="KİLİTLENME"
                                          Subtitle="Şartname m. 6.1.1 — tolerans, pencere, gerekli süre">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Boyut toleransı" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="3" Maximum="10" TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding LockTolerancePercent}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="LockTolerancePercent" StringFormat="{}%{0:0}" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pencere süresi" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="3" Maximum="10" TickFrequency="0.5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding LockWindowSeconds}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="LockWindowSeconds" StringFormat="{}{0:0.0} sn" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Gerekli süre" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="2" Maximum="8" TickFrequency="0.5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding LockRequiredSeconds}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="LockRequiredSeconds" StringFormat="{}{0:0.0} sn" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </core:SettingsSection>

                    <Border Style="{StaticResource SectionDivider}" />

                    <core:SettingsSection IconKind="Bomb"
                                          Title="KAMİKAZE"
                                          Subtitle="TYF: 100m → 45° dalış → 30m pas geç">
                        <StackPanel>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Başlangıç irtifası" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="50" Maximum="200" TickFrequency="10"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding KamikazeApproachAltitude}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalAccent}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="KamikazeApproachAltitude" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Dalış açısı" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="20" Maximum="70" TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding KamikazeDiveAngle}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalWarn}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="KamikazeDiveAngle" StringFormat="{}{0:0}°" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Grid Style="{StaticResource FieldRow}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pas geç irtifası" Style="{StaticResource FieldLabel}" />
                                <Slider Grid.Column="1" Minimum="20" Maximum="80" TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding KamikazePullUpAltitude}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="12" MinWidth="60"
                                           Foreground="{StaticResource TacticalOk}"
                                           VerticalAlignment="Center" TextAlignment="Right">
                                    <TextBlock.Text><Binding Path="KamikazePullUpAltitude" StringFormat="{}{0:0} m" /></TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </core:SettingsSection>

                </StackPanel>
            </ScrollViewer>
        </core:IconTabItem>
    </TabControl>
</UserControl>
